{
	"note": "Example configuration for an rss.chat server. Copy this to config.json (which is gitignored) and replace the values with your own. Never commit a real config.json -- it holds your database password.",
	"productName": "rssChat",
	"productNameForDisplay": "myserver.chat",
	"urlServerHomePageSource": "https://code.scripting.com/rsschat/index.html",
	"myDomain": "myserver.chat",
	"urlServerForClient": "https://myserver.chat/",
	"urlServerForEmail": "https://myserver.chat/",
	"flWebsocketEnabled": true,
	"websocketPort": 1462,
	"flSecureWebsocket": true,
	"urlWebsocketServerForClient": "wss://myserver.chat/",
	"prefsPath": "prefs.json",
	"dataPath": "data/",
	"flFeedsInDatabase": true,
	"extraFeeds": [
		{"name": "rss.chat", "xmlUrl": "https://rss.chat/users/rss.xml"},
		{"name": "Wired Top Stories", "shortName": "Top Stories", "group": "Wired", "groupUrl": "https://www.wired.com/", "xmlUrl": "https://www.wired.com/feed/rss"},
		{"name": "Wired Backchannel", "shortName": "Backchannel", "group": "Wired", "groupUrl": "https://www.wired.com/", "xmlUrl": "https://www.wired.com/feed/category/backchannel/latest/rss"}
		],
	"localSourceLabel": "myserver.chat",
	"crossPostTargets": [
		{"name": "demo.rss.chat", "url": "https://demo.rss.chat/"},
		{"name": "my blog", "type": "wordpress", "idSite": 123456789, "flMirrorTimeline": true}
		],
	"mailSender": "admin@myserver.chat",
	"confirmEmailSubject": "myserver.chat confirmation",
	"operationToConfirm": "sign in to myserver.chat",
	"database": {
		"host": "your-cluster.db.ondigitalocean.com",
		"port": 25060,
		"user": "doadmin",
		"password": "your-db-password",
		"charset": "utf8mb4",
		"connectionLimit": 100,
		"database": "myRssChat",
		"debug": false
		}
	}
