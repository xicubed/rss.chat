								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function pingCloud (screenname) {">
						<outline text="var urlFeed = &quot;http://&quot; + config.myDomain + &quot;/feed?screenname=&quot; + screenname;"/>
						<outline text="rss.cloudPing (undefined, urlFeed, function (err) {">
