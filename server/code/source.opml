					<outline text="urlWebsocketServerForClient: &quot;&quot;,"/>
					<outline text="flWebsocketEnabled: false,"/>
					<outline text="prefsPath: &quot;prefs.json&quot;," created="Fri, 24 Apr 2026 21:29:56 GMT"/>
					<outline text="" created="Fri, 24 Apr 2026 21:28:44 GMT"/>
					<outline text="dataPath: &quot;data/&quot;,"/>
					<outline text="maxFeedItems: 100,"/>
					<outline text="" created="Sat, 25 Apr 2026 15:31:22 GMT"/>
					<outline text="rssLanguage: &quot;en-us&quot;,"/>
					<outline text="rssDocs: &quot;http://cyber.law.harvard.edu/rss/rss.html&quot;,"/>
					<outline text="rssMaxFeedItems: 100,"/>
					<outline text="flRssCloudEnabled: true,"/>
