							<outline text="});" created="Fri, 01 May 2026 15:34:21 GMT"/>
							</outline>
						<outline text="}" created="Fri, 01 May 2026 15:32:15 GMT"/>
						</outline>
					<outline text="function checkWhitelist (emailaddress, callback) { //6/9/26 by DW" created="Tue, 09 Jun 2026 21:57:10 GMT">
						<outline text="Changes" isComment="true" created="Tue, 09 Jun 2026 22:01:12 GMT">
							<outline text="6/9/26; 6:01:14 PM by DW" created="Tue, 09 Jun 2026 22:01:13 GMT">
								<outline text="Cribbed from daveappserver. It does its checking for whitelisting for the logged-in user, we want to check it before we let the user do an email validation. So we needed another endpoint. I didn't want to mess with daveappserver now. " created="Tue, 09 Jun 2026 22:01:15 GMT"/>
								</outline>
							</outline>
						<outline text="fs.readFile (&quot;config.json&quot;, function (err, jsontext) {" created="Fri, 16 Sep 2022 13:07:26 GMT">
							<outline text="var flWhitelisted = false; " created="Thu, 21 Jul 2022 19:44:33 GMT"/>
							<outline text="if (err) {" created="Wed, 10 Jun 2026 15:04:42 GMT">
								<outline text="console.log (&quot;checkWhitelist: err.message == &quot; + err.message);" created="Fri, 22 Jul 2022 14:04:30 GMT"/>
								<outline text="}" created="Wed, 10 Jun 2026 15:04:46 GMT"/>
								</outline>
							<outline text="else {" created="Wed, 10 Jun 2026 15:04:47 GMT">
								<outline text="var jstruct;" created="Fri, 16 Sep 2022 13:14:16 GMT"/>
								<outline text="try {" created="Fri, 16 Sep 2022 13:11:45 GMT">
									<outline text="jstruct = JSON.parse (jsontext);" created="Fri, 16 Sep 2022 13:08:14 GMT"/>
									<outline text="if (jstruct.whitelist === undefined) { //no whitelist" created="Thu, 21 Jul 2022 19:42:04 GMT">
										<outline text="flWhitelisted = true;" created="Fri, 16 Sep 2022 13:13:16 GMT"/>
										<outline text="}" created="Thu, 21 Jul 2022 19:42:23 GMT"/>
										</outline>
									<outline text="else {" created="Fri, 16 Sep 2022 13:13:14 GMT">
										<outline text="flWhitelisted = jstruct.whitelist.includes (emailaddress);" created="Fri, 22 Jul 2022 14:47:40 GMT"/>
										<outline text="}" created="Fri, 16 Sep 2022 13:13:23 GMT"/>
										</outline>
									<outline text="}" created="Fri, 16 Sep 2022 13:11:48 GMT"/>
									</outline>
								<outline text="catch (err) {" created="Fri, 16 Sep 2022 13:11:49 GMT">
									<outline text="console.log (&quot;checkWhitelist: err.message == &quot; + err.message);" created="Fri, 22 Jul 2022 14:04:30 GMT"/>
									<outline text="}" created="Fri, 16 Sep 2022 13:11:53 GMT"/>
									</outline>
								<outline text="}" created="Wed, 10 Jun 2026 15:04:49 GMT"/>
								</outline>
							<outline text="console.log (&quot;checkWhitelist: emailaddress == &quot; + emailaddress + &quot;, flWhitelisted == &quot; + flWhitelisted);" isComment="true" created="Fri, 22 Jul 2022 14:04:30 GMT"/>
							<outline text="callback (undefined, {flWhitelisted});" created="Fri, 16 Sep 2022 13:06:41 GMT"/>
							<outline text="});" created="Fri, 16 Sep 2022 13:07:50 GMT"/>
							</outline>
						<outline text="}" created="Tue, 09 Jun 2026 21:57:26 GMT"/>
						</outline>
					<outline text="function getLikersList (id, callback) { //6/25/26 by CC ">
						<outline text="Changes" isComment="true" created="Thu, 25 Jun 2026 15:52:02 GMT">
							<outline text="6/25/26; 11:52:06 AM by DW" created="Thu, 25 Jun 2026 15:52:05 GMT">
								<outline text="returns an array of screennames of users who liked an item, oldest first; powers the like tooltip." created="Thu, 25 Jun 2026 15:52:07 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select screenname from likes where itemId = &quot; + davesql.encode (id) + &quot; order by whenCreated;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var screennames = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="screennames.push (row.screenname);"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, screennames);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getMostActiveToday (callback) { //7/1/26 by CC">
						<outline text="Changes" isComment="true" created="Wed, 01 Jul 2026 14:59:28 GMT">
							<outline text="7/1/26; 10:59:32 AM by DW" created="Wed, 01 Jul 2026 14:59:31 GMT">
								<outline text="#122: the users with the most hits today, most active first, capped at 100" created="Wed, 01 Jul 2026 14:59:32 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select screenname, coalesce (nullif (prefs -&gt;&gt; '$.myFeedTitle', ''), screenname) as name, prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, ctHits, ctHitsToday, whenLastHit from users order by ctHitsToday desc, ctHits desc limit 100;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var theList = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="const oneRec = {">
										<outline text="screenname: convertString (row.screenname),"/>
										<outline text="name: convertString (row.name),"/>
										<outline text="imageUrl: convertString (row.imageUrl),"/>
										<outline text="ctHits: convertNumber (row.ctHits),"/>
										<outline text="ctHitsToday: convertNumber (row.ctHitsToday),"/>
										<outline text="whenLastHit: convertDate (row.whenLastHit)"/>
										<outline text="};"/>
										</outline>
									<outline text="theList.push (oneRec);"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, theList);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getItemInfo (screenname, guid, id, format, callback) { //7/9/26 by CC &amp; DW">
						<outline text="Changes" isComment="true">
							<outline text="7/9/26; 12:46:39 PM by DW" created="Thu, 09 Jul 2026 16:46:38 GMT">
								<outline text="Easier to support new formats. " created="Thu, 09 Jul 2026 16:46:39 GMT"/>
								</outline>
							<outline text="7/9/26 by CC ">
								<outline text="first version. The other end of a source:inReplyTo link, for apps other than rss.chat. Default rendering is the item in feed vocabulary as JSON -- the same struct buildFeedItems hands daverss, with inReplyTo, comments and source. format=feedland returns the internal structure, same as the firehose." created="Thu, 09 Jul 2026 15:41:35 GMT"/>
								</outline>
							</outline>
						<outline text="if (id !== undefined) { //caller can pass id instead of guid">
							<outline text="guid = config.urlServerForClient + &quot;?id=&quot; + id;"/>
							<outline text="}"/>
							</outline>
						<outline text="getItemByGuid (screenname, guid, function (err, itemRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (itemRec === undefined) {">
									<outline text="const message = &quot;Can't get info about the post &quot; + guid + &quot; because there is no post with that address.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="switch (format) {" created="Thu, 09 Jul 2026 16:40:11 GMT">
										<outline text="case undefined: case &quot;rss&quot;: " created="Thu, 09 Jul 2026 16:40:21 GMT">
											<outline text="const feedItems = buildFeedItems ([itemRec], true);"/>
											<outline text="callback (undefined, feedItems [0]);"/>
											<outline text="break;" created="Thu, 09 Jul 2026 16:40:32 GMT"/>
											</outline>
										<outline text="case &quot;feedland&quot;: " created="Thu, 09 Jul 2026 16:40:21 GMT">
											<outline text="callback (undefined, itemRec);"/>
											<outline text="break;" created="Thu, 09 Jul 2026 16:40:32 GMT"/>
											</outline>
										<outline text="default: " created="Thu, 09 Jul 2026 16:40:21 GMT">
											<outline text="const message = &quot;Can't get info about the post because there is no format named \&quot;&quot; + format + &quot;\&quot;. The formats are \&quot;rss\&quot; and \&quot;feedland\&quot;.&quot;;"/>
											<outline text="callback ({message});"/>
											<outline text="break;" created="Thu, 09 Jul 2026 16:40:32 GMT"/>
											</outline>
										<outline text="}" created="Thu, 09 Jul 2026 16:40:20 GMT"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Tue, 09 Jun 2026 21:57:11 GMT"/>
					</outline>
				<outline text="//like -- 6/24/26 by DW" created="Wed, 24 Jun 2026 21:50:24 GMT">
					<outline text="function addToLikesTable (screenname, itemId, callback) {">
						<outline text="const likesRec = {">
							<outline text="screenname,"/>
							<outline text="itemId,"/>
							<outline text="whenCreated: new Date ()"/>
							<outline text="};"/>
							</outline>
						<outline text="const sqltext = &quot;replace into likes &quot; + davesql.encodeValues (likesRec);"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="if (callback !== undefined) {">
									<outline text="callback (err);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (callback !== undefined) {">
									<outline text="callback (undefined, likesRec);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function removeFromLikesTable (screenname, itemId, callback) {">
						<outline text="const sqltext = &quot;delete from likes where screenname = &quot; + davesql.encode (screenname) + &quot; and itemId = &quot; + davesql.encode (itemId) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="if (callback !== undefined) {">
									<outline text="callback (err);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (callback !== undefined) {">
									<outline text="callback (undefined, {});"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function isLiked (screenname, itemId, callback) {">
						<outline text="const sqltext = &quot;select count(*) as ct from likes where screenname = &quot; + davesql.encode (screenname) + &quot; and itemId = &quot; + davesql.encode (itemId) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="const flLiked = result [0].ct &gt; 0;"/>
								<outline text="callback (undefined, flLiked);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function toggleLike (screenname, itemId, callback) {">
						<outline text="isLiked (screenname, itemId, function (err, flLiked) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="function done (err) {">
									<outline text="if (err) {">
										<outline text="callback (err);"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="getItemById (screenname, itemId, function (err, item) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="notifySocketSubscribers (&quot;updatedItem&quot;, {item});"/>
												<outline text="callback (undefined, item);"/>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="if (flLiked) {">
									<outline text="removeFromLikesTable (screenname, itemId, done);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="addToLikesTable (screenname, itemId, done);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Wed, 24 Jun 2026 22:23:45 GMT"/>
					<outline text="function toggleLikeEndpoint (email, code, id, callback) { //6/24/26 by DW">
						<outline text="validateUser (email, code, &quot;toggle the like&quot;, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (id === undefined) {">
									<outline text="const message = &quot;Can't toggle the like because no id was provided.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="toggleLike (userRec.screenname, id, callback);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Wed, 24 Jun 2026 22:23:45 GMT"/>
					<outline text="" created="Wed, 24 Jun 2026 22:23:46 GMT"/>
					</outline>
				<outline text="//feedland" isComment="true" created="Sat, 25 Apr 2026 16:48:57 GMT">
					<outline text="function httpRequest (url, timeout, headers, callback) {">
						<outline text="request (url, function (err, response, data) { ">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (response.statusCode != 200) {">
									<outline text="callback ({message: &quot;Error: &quot; + data.toString ()});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, data.toString ());"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function servercall (path, params, flAuthenticated=false, callback, urlServer=config.urlFeedlandServer) {">
						<outline text="Changes" isComment="true">
							<outline text="6/4/26; 10:24:40 AM by DW" created="Thu, 04 Jun 2026 14:24:40 GMT">
								<outline text="Check error on JSON.parse call." created="Thu, 04 Jun 2026 14:24:40 GMT"/>
								</outline>
							<outline text="11/24/25; 4:22:03 PM by DW" created="Mon, 24 Nov 2025 21:22:02 GMT">
								<outline text="If it's an error, but the code is 404, return an empty object, no error." created="Mon, 24 Nov 2025 21:22:03 GMT"/>
								</outline>
							<outline text="11/3/23; 11:58:44 AM by DW" created="Fri, 03 Nov 2023 15:58:44 GMT">
								<outline text="Support localStorage.adminActingAs." created="Fri, 03 Nov 2023 15:58:45 GMT"/>
								</outline>
							<outline text="4/22/23; 1:24:18 PM by DW" created="Sat, 22 Apr 2023 17:24:17 GMT">
								<outline text="Change twBuildParamList call to buildParamList." created="Sat, 22 Apr 2023 17:24:19 GMT"/>
								</outline>
							<outline text="12/23/22; 10:30:22 PM by DW" created="Sat, 24 Dec 2022 03:30:22 GMT">
								<outline text="Support email params. Don't send oauth token if it's not defined." created="Sat, 24 Dec 2022 03:30:22 GMT"/>
								</outline>
							<outline text="12/10/21; 12:51:58 PM by DW" created="Fri, 10 Dec 2021 17:51:57 GMT">
								<outline text="New optional parameter, urlServer, so this function can be used to call Daytona." created="Fri, 10 Dec 2021 17:51:58 GMT"/>
								</outline>
							<outline text="1/11/21; 12:51:47 PM by DW">
								<outline text="New param, flAuthenticated. If true we add the oAuth info to the call. "/>
								</outline>
							</outline>
						<outline text="var whenstart = new Date ();"/>
						<outline text="if (params === undefined) {">
							<outline text="params = new Object ();"/>
							<outline text="}"/>
							</outline>
						<outline text="if (flAuthenticated) { //1/11/21 by DW">
							<outline text="if (localStorage.twOauthToken !== undefined) { //12/23/22 by DW" created="Sat, 24 Dec 2022 03:29:45 GMT">
								<outline text="params.oauth_token = localStorage.twOauthToken;"/>
								<outline text="params.oauth_token_secret = localStorage.twOauthTokenSecret;"/>
								<outline text="}" created="Sat, 24 Dec 2022 03:29:55 GMT"/>
								</outline>
							<outline text="addEmailParams (params); //12/13/22 by DW" created="Tue, 13 Dec 2022 21:39:41 GMT"/>
							<outline text="}"/>
							</outline>
						<outline text="var url = urlServer + path + &quot;?&quot; + utils.buildParamList (params, false);" created="Sat, 09 Aug 2014 16:02:57 GMT" pgfnum="43215"/>
						<outline text="console.log (&quot;servercall: url == &quot; + url);" isComment="true" created="Mon, 30 Jan 2023 17:35:43 GMT"/>
						<outline text="httpRequest (url, undefined, undefined, function (err, jsontext) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;servercall: url == &quot; + url + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="console.log (&quot;servercall: jsontext.length == &quot; + jsontext.length + &quot;, secs == &quot; + secondsSince (whenstart)); " isComment="true"/>
								<outline text="" created="Thu, 04 Jun 2026 14:20:42 GMT"/>
								<outline text="var jstruct, flError = true;" created="Thu, 04 Jun 2026 14:20:42 GMT"/>
								<outline text="try {" created="Thu, 04 Jun 2026 14:20:53 GMT">
									<outline text="jstruct = JSON.parse (jsontext);" created="Thu, 04 Jun 2026 14:21:04 GMT"/>
									<outline text="flError = false;" created="Thu, 04 Jun 2026 14:23:24 GMT"/>
									<outline text="}" created="Thu, 04 Jun 2026 14:20:59 GMT"/>
									</outline>
								<outline text="catch (err) {" created="Thu, 04 Jun 2026 14:21:20 GMT">
									<outline text="const message = &quot;Can't complete the server call because the JSON text it returned does not parse.&quot;;" created="Thu, 04 Jun 2026 14:21:29 GMT"/>
									<outline text="callback ({message});" created="Thu, 04 Jun 2026 14:22:12 GMT"/>
									<outline text="}" created="Thu, 04 Jun 2026 14:21:23 GMT"/>
									</outline>
								<outline text="if (!flError) {" created="Thu, 04 Jun 2026 14:22:54 GMT">
									<outline text="callback (undefined, jstruct);"/>
									<outline text="}" created="Thu, 04 Jun 2026 14:23:03 GMT"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getFeedlandItemFromFeed (feedUrl, guid, callback) { " isComment="true" created="Thu, 19 Feb 2026 14:08:44 GMT">
						<outline text="servercall (&quot;getitemfromfeed&quot;, {url: feedUrl, guid}, false, callback);"/>
						<outline text="}" created="Thu, 19 Feb 2026 14:09:38 GMT"/>
						</outline>
					<outline text="function getFeedlandItemFromPermalink (screenname, permalinkCode, callback) {" isComment="true" created="Sat, 25 Apr 2026 17:02:48 GMT">
						<outline text="Changes" isComment="true" created="Sun, 26 Apr 2026 14:16:29 GMT">
							<outline text="4/26/26; 10:16:33 AM by DW" created="Sun, 26 Apr 2026 14:16:32 GMT">
								<outline text="give me a screenname and a permalink code and I'll give you the feedland item record for that post. " created="Sun, 26 Apr 2026 14:16:34 GMT"/>
								</outline>
							</outline>
						<outline text="const feedUrl = getFeedUrl (screenname);" created="Sat, 25 Apr 2026 17:20:42 GMT"/>
						<outline text="const guid = getPermalinkUrl (screenname, permalinkCode);" created="Sat, 25 Apr 2026 17:34:03 GMT"/>
						<outline text="getFeedlandItemFromFeed (feedUrl, guid, callback);" created="Sat, 25 Apr 2026 17:20:42 GMT"/>
						<outline text="getFeedlandItemFromFeed (feedUrl, guid, function (err, item) {" isComment="true" created="Sat, 25 Apr 2026 17:20:42 GMT">
							<outline text="if (err) {" created="Sat, 25 Apr 2026 17:34:26 GMT">
								<outline text="console.log (&quot;viewFeedlandPermalink: err.message == &quot; + err.message);" created="Sat, 25 Apr 2026 17:34:58 GMT"/>
								<outline text="callback (err);" created="Sat, 25 Apr 2026 17:58:42 GMT"/>
								<outline text="}" created="Sat, 25 Apr 2026 17:34:31 GMT"/>
								</outline>
							<outline text="else {" created="Sat, 25 Apr 2026 17:34:32 GMT">
								<outline text="console.log (&quot;viewFeedlandPermalink: item == &quot; + utils.jsonStringify (item));" created="Sat, 25 Apr 2026 17:34:58 GMT"/>
								<outline text="callback (undefined, item);" created="Sat, 25 Apr 2026 17:58:42 GMT"/>
								<outline text="}" created="Sat, 25 Apr 2026 17:34:35 GMT"/>
								</outline>
							<outline text="});" created="Sat, 25 Apr 2026 17:21:45 GMT"/>
							</outline>
						<outline text="}" created="Sat, 25 Apr 2026 17:03:05 GMT"/>
						</outline>
					</outline>
				<outline text="//callbacks for daveappserver" created="Mon, 27 Apr 2026 13:34:14 GMT">
					<outline text="function findUserWithScreenname (screenname, callback) {">
						<outline text="getUserInfoByScreenname (screenname, function (err, userInfo) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;findUserWithScreenname: screenname == &quot; + screenname + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (false);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userInfo === undefined) {">
									<outline text="callback (false);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (true, userInfo);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function findUserWithEmail (email, callback) {">
						<outline text="getUserInfoByEmail (email, function (err, userInfo) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;findUserWithEmail: email == &quot; + email + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (false);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userInfo === undefined) {">
									<outline text="callback (false);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (true, {">
										<outline text="emailAddress: userInfo.emailAddress, " created="Mon, 27 Apr 2026 13:50:44 GMT"/>
										<outline text="emailSecret: userInfo.emailSecret" created="Mon, 27 Apr 2026 13:50:49 GMT"/>
										<outline text="});" created="Mon, 27 Apr 2026 13:50:57 GMT"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getScreenNameFromEmail (email, callback) {">
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;getScreenNameFromEmail: email == &quot; + email + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't get the user's screenname because the user wasn't found.&quot;;" created="Mon, 27 Apr 2026 13:54:25 GMT"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, userRec.screenname);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function addEmailToUserInDatabase (screenname, email, magicString, flNewUser, callback) {">
						<outline text="Changes" isComment="true" created="Sun, 10 May 2026 16:42:23 GMT">
							<outline text="5/10/26; 12:42:25 PM by DW" created="Sun, 10 May 2026 16:42:25 GMT">
								<outline text="We now re-use the secret." created="Sun, 10 May 2026 16:42:26 GMT"/>
								</outline>
							</outline>
						<outline text="getUserInfoByScreenname (screenname, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;addEmailToUserInDatabase: screenname == &quot; + screenname + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const emailSecret = utils.getRandomPassword (20);"/>
									<outline text="const newRec = {">
										<outline text="screenname: screenname,"/>
										<outline text="emailAddress: email,"/>
										<outline text="emailSecret: emailSecret"/>
										<outline text="};"/>
										</outline>
									<outline text="addUser (newRec, function (err) {">
										<outline text="if (err) {">
											<outline text="callback (err);"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="callback (undefined, emailSecret);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, userRec.emailSecret);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function addEmailToUserInDatabase (screenname, email, magicString, flNewUser, callback) {" isComment="true">
						<outline text="const emailSecret = utils.getRandomPassword (20);"/>
						<outline text="getUserInfoByScreenname (screenname, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;addEmailToUserInDatabase: screenname == &quot; + screenname + &quot;, err.message == &quot; + err.message);"/>
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const newRec = {">
										<outline text="screenname: screenname,"/>
										<outline text="emailAddress: email,"/>
										<outline text="emailSecret: emailSecret"/>
										<outline text="};"/>
										</outline>
									<outline text="addUser (newRec, function (err) {">
										<outline text="if (err) {">
											<outline text="callback (err);"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="callback (undefined, emailSecret);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="userRec.emailAddress = email;"/>
									<outline text="userRec.emailSecret = emailSecret;"/>
									<outline text="updateUser (userRec, function (err) {">
										<outline text="if (err) {">
											<outline text="callback (err);"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="callback (undefined, emailSecret);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function isUserAdmin (email, callback) {">
						<outline text="callback (false);"/>
						<outline text="}"/>
						</outline>
					</outline>
				<outline text="" created="Wed, 22 Apr 2026 21:58:59 GMT"/>
				<outline text="function handleHttpRequest (theRequest) {" created="Wed, 22 Apr 2026 21:58:59 GMT">
					<outline text="const params = theRequest.params;"/>
					<outline text="" isComment="true" created="Fri, 26 Jun 2026 17:46:52 GMT"/>
					<outline text="if (theRequest.lowerpath === &quot;/&quot;) { //6/26/26 by DW" isComment="true">
						<outline text="console.log (&quot;handleHttpRequest: headers == &quot; + utils.jsonStringify (theRequest.sysRequest.headers) + &quot;, flLocalRequest == &quot; + theRequest.flLocalRequest);"/>
						<outline text="}"/>
						</outline>
					<outline text="" created="Wed, 22 Apr 2026 22:09:59 GMT"/>
					<outline text="function returnXml (s) {">
						<outline text="theRequest.httpReturn (200, &quot;application/rss+xml&quot;, s);"/>
						<outline text="}"/>
						</outline>
					<outline text="function returnData (jstruct) {">
						<outline text="if (jstruct === undefined) {">
							<outline text="jstruct = {};"/>
							<outline text="}"/>
							</outline>
						<outline text="theRequest.httpReturn (200, &quot;application/json&quot;, utils.jsonStringify (jstruct));"/>
						<outline text="}"/>
						</outline>
					<outline text="function returnText (theText) { //7/1/26 by DW">
						<outline text="theRequest.httpReturn (200, &quot;text/plain&quot;, theText);"/>
						<outline text="}"/>
						</outline>
					<outline text="function returnError (err) {" created="Mon, 28 Feb 2022 14:38:48 GMT">
						<outline text="console.log (&quot;returnError: err.message == &quot; + err.message); //5/10/26 by DW" created="Sun, 10 May 2026 14:39:46 GMT"/>
						<outline text="theRequest.httpReturn (503, &quot;text/plain&quot;, err.message);"/>
						<outline text="}" created="Mon, 28 Feb 2022 14:38:53 GMT"/>
						</outline>
					<outline text="function httpReturn (err, data) {" created="Mon, 28 Feb 2022 14:38:48 GMT">
						<outline text="if (err) {" created="Thu, 27 Jan 2022 16:15:45 GMT">
							<outline text="if (err.code !== undefined) { //2/22/25 by DW -- let the caller determine the code" created="Sat, 22 Feb 2025 14:35:03 GMT">
