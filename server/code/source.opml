					<outline text="function returnRedirect (url, code=undefined) {">
						<outline text="var headers = {">
							<outline text="location: url"/>
							<outline text="};"/>
							</outline>
						<outline text="if (code === undefined) {">
							<outline text="code = 302;"/>
							<outline text="}"/>
							</outline>
						<outline text="console.log (&quot;returnRedirect: code == &quot; + code + &quot;, url == &quot; + url);" isComment="true" created="Sun, 26 Apr 2026 14:46:27 GMT"/>
						<outline text="theRequest.httpReturn (code, &quot;text/plain&quot;, code + &quot; REDIRECT&quot;, headers);"/>
						<outline text="}"/>
						<outline text=""/>
						</outline>
