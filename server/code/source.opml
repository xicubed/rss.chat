					<outline text="productName: &quot;rssNetwork&quot;," created="Fri, 24 Apr 2026 21:28:33 GMT"/>
					<outline text="productNameForDisplay: &quot;rssNetwork&quot;, " created="Fri, 24 Apr 2026 21:28:43 GMT"/>
					<outline text="urlServerHomePageSource: &quot;http://scripting.com/code/testing/rssnetwork/client/index.html&quot;," created="Fri, 24 Apr 2026 21:28:44 GMT"/>
