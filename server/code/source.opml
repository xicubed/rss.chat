				<outline text="# rssNetwork" created="Wed, 15 Apr 2026 14:07:00 GMT">
					<outline text=" A simple server that supports communities of users of rss.chat and compatible products. " created="Wed, 15 Apr 2026 14:07:05 GMT"/>
