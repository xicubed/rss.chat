					<outline text="" created="Sat, 13 Jun 2026 15:47:33 GMT"/>
					<outline text="function getUserData (screenname, callback) {" created="Wed, 22 Apr 2026 22:36:55 GMT">
						<outline text="Changes" isComment="true" created="Sun, 17 May 2026 20:26:54 GMT">
							<outline text="6/13/26; 11:23:44 AM by DW" created="Sat, 13 Jun 2026 15:23:44 GMT">
								<outline text="It should work if the screenname is not provided, or is not valid. We need to get certain basic data back that isn't actually specific to a user. " created="Sat, 13 Jun 2026 15:23:45 GMT"/>
								</outline>
							<outline text="6/4/26; 9:44:33 AM by DW" created="Thu, 04 Jun 2026 13:44:32 GMT">
								<outline text="Sometimes getUserInfoByScreenname returns with an undefined user record and doesn't call it an error." created="Thu, 04 Jun 2026 13:44:33 GMT"/>
								</outline>
							<outline text="5/17/26; 4:26:59 PM by DW" created="Sun, 17 May 2026 20:26:59 GMT">
								<outline text="Called by client at startup, instead of making 20 calls, it just makes one, to get the bundle." created="Sun, 17 May 2026 20:26:59 GMT"/>
								</outline>
							</outline>
						<outline text="var theData = { //6/13/26 by DW" created="Sat, 13 Jun 2026 15:27:24 GMT">
							<outline text="feedUrlEveryone: config.rssFeedUrl + config.rssFilename, //6/5/26 by DW" created="Wed, 22 Apr 2026 17:16:27 GMT"/>
							<outline text="baseFeedUrl: config.rssFeedUrl," created="Thu, 23 Apr 2026 12:18:20 GMT"/>
							<outline text="opmlListUrl: config.opmlListUrl, //6/5/26 by DW"/>
							<outline text="flWhitelist: config.whitelist !== undefined, //6/10/26 by DW" created="Wed, 10 Jun 2026 15:11:17 GMT"/>
							<outline text="urlFeedlandServer: config.urlFeedlandServer," created="Sat, 25 Apr 2026 17:54:40 GMT"/>
							<outline text="serverVersion: myVersion, //7/1/26 by DW" created="Wed, 01 Jul 2026 13:04:05 GMT"/>
							<outline text="mySqlVersion: config.mysqlVersion, //7/1/26 by DW" created="Wed, 01 Jul 2026 13:25:07 GMT"/>
							<outline text="}" created="Sat, 13 Jun 2026 15:27:32 GMT"/>
							</outline>
						<outline text="if (screenname === undefined) {" created="Sat, 13 Jun 2026 15:44:09 GMT">
							<outline text="callback (undefined, theData);" created="Wed, 22 Apr 2026 17:13:19 GMT"/>
							<outline text="}" created="Sat, 13 Jun 2026 15:44:18 GMT"/>
							</outline>
						<outline text="else {" created="Sat, 13 Jun 2026 15:44:18 GMT">
							<outline text="getUserInfoByScreenname (screenname, function (err, theUser) {" created="Sat, 16 May 2026 20:44:41 GMT">
								<outline text="if (err) {" created="Sat, 16 May 2026 20:45:07 GMT">
									<outline text="callback (err);" created="Wed, 22 Apr 2026 17:13:19 GMT"/>
									<outline text="}" created="Sat, 16 May 2026 20:45:12 GMT"/>
									</outline>
								<outline text="else {" created="Sat, 16 May 2026 20:45:13 GMT">
									<outline text="if (theUser === undefined) {" created="Thu, 04 Jun 2026 13:41:32 GMT">
										<outline text="const message = &quot;Can't get user data for \&quot;&quot; + screenname + &quot;\&quot; because there is no user with that name.&quot;;" created="Thu, 04 Jun 2026 13:41:47 GMT"/>
										<outline text="callback ({message});" created="Thu, 04 Jun 2026 13:42:21 GMT"/>
										<outline text="}" created="Thu, 04 Jun 2026 13:41:37 GMT"/>
										</outline>
									<outline text="else {" created="Thu, 04 Jun 2026 13:41:37 GMT">
										<outline text="const moreData = {" created="Wed, 22 Apr 2026 22:37:09 GMT">
											<outline text="screenname, //6/9/26 by DW" created="Tue, 09 Jun 2026 22:20:25 GMT"/>
											<outline text="feedUrl: getFeedUrl (screenname)," created="Wed, 22 Apr 2026 17:16:27 GMT"/>
											<outline text="imageUrl: theUser.imageUrl, //5/16/26 by DW" created="Sat, 16 May 2026 20:47:36 GMT"/>
											<outline text="whenUserCreated: theUser.whenCreated, //5/16/26 by DW" created="Sat, 16 May 2026 20:48:35 GMT"/>
											<outline text="whenUserUpdated: theUser.whenUpdated, //5/16/26 by DW" created="Sat, 16 May 2026 20:48:40 GMT"/>
											<outline text="prefs: theUser.prefs, //5/16/26 by DW" created="Sat, 16 May 2026 20:49:06 GMT"/>
											<outline text="}" created="Wed, 22 Apr 2026 22:37:40 GMT"/>
											</outline>
										<outline text="utils.mergeOptions (moreData, theData);" created="Sat, 13 Jun 2026 15:34:31 GMT"/>
										<outline text="callback (undefined, theData);" created="Wed, 22 Apr 2026 17:13:19 GMT"/>
										<outline text="}" created="Thu, 04 Jun 2026 13:41:40 GMT"/>
