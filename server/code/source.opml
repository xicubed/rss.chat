												<outline text="const s3path = config.rssS3Path + relpath;" created="Wed, 22 Apr 2026 14:43:48 GMT"/>
												<outline text="console.log (&quot;updateFeedsOnS3: s3path == &quot; + s3path);" isComment="true"/>
												<outline text="s3.newObject (s3path, xmltext, &quot;text/xml&quot;, &quot;public-read&quot;, function (err, data) {">
													<outline text="if (err) {">
														<outline text="console.log (&quot;updateFeedsOnS3: config.rssS3Path == &quot; + config.rssS3Path + &quot;, err.message == &quot; + err.message);"/>
