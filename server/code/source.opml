					<outline text="function getPermalinkUrl (screenname, permalinkCode) {" isComment="true" created="Sat, 25 Apr 2026 17:32:39 GMT">
						<outline text="const url = config.urlServerForClient + &quot;permalink?screenname=&quot; + screenname + &quot;&amp;id=&quot; + permalinkCode;" created="Sat, 25 Apr 2026 17:32:51 GMT"/>
						<outline text="return (url);" created="Sat, 25 Apr 2026 17:33:14 GMT"/>
