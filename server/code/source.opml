				<outline text="//opml subscription list" created="Thu, 23 Apr 2026 14:49:52 GMT">
					<outline text="function getSubscriptionList (callback) {">
						<outline text="getAllScreennames (function (err, theNames) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="const nowstring = new Date ().toGMTString ();"/>
								<outline text="var theOutline = {">
									<outline text="opml: {">
										<outline text="head: {">
											<outline text="title: &quot;Subscription list for &quot; + myProductName + &quot; running on &quot; + config.myDomain,"/>
