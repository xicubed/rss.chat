				<outline text="# How to install a rssNetwork server" created="Wed, 15 Apr 2026 14:26:35 GMT">
					<outline text="Here we put instructions for a new host-runner. " created="Wed, 15 Apr 2026 14:26:55 GMT"/>
					</outline>
				<outline text="### Edit config.json" created="Wed, 15 Apr 2026 14:27:10 GMT">
					<outline text="Included is an example of what's in a config.json file, with the settings you're likely to want to edit to customize your installation. " created="Wed, 15 Apr 2026 14:27:23 GMT"/>
					</outline>
				<outline text="### Create your database" created="Sun, 26 Apr 2026 20:53:44 GMT">
					<outline text="Instructions are in &lt;a href=&quot;setup.sql&quot;&gt;setup.sql&lt;/a&gt;. " created="Sun, 26 Apr 2026 20:53:51 GMT"/>
					</outline>
				</outline>
