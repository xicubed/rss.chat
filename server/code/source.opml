					<outline text="" created="Sat, 13 Jun 2026 15:27:13 GMT"/>
					<outline text="function getUserFeed (screenname, callback) {">
						<outline text="getUserInfoByScreenname (screenname, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't get the feed because there is no user with screenname \&quot;&quot; + screenname + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="buildFeedForUser (userRec, function (err, xmltext) {">
										<outline text="if (err) {">
											<outline text="console.log (&quot;getUserFeed: err.message == &quot; + err.message);"/>
											<outline text="callback (err);"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="callback (undefined, xmltext);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getFeedForAllUsers (callback) { //6/3/26 by DW" isComment="true">
						<outline text="buildFeedForEveryone (function (err, xmltext) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;getFeedForAllUsers: err.message == &quot; + err.message);"/>
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="callback (undefined, xmltext);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function newPost (email, code, jsontext, callback) {">
						<outline text="Changes" isComment="true" created="Thu, 30 Apr 2026 15:34:03 GMT">
							<outline text="4/30/26; 11:34:07 AM by DW" created="Thu, 30 Apr 2026 15:34:06 GMT">
								<outline text="instead of just receiving the text, we recieve a JSON string to carry the whole object." created="Thu, 30 Apr 2026 15:34:07 GMT"/>
								</outline>
							</outline>
						<outline text="console.log (&quot;newPost: email == &quot; + email + &quot;, code == &quot; + code); //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 14:29:51 GMT"/>
						<outline text="var postRec;" created="Thu, 30 Apr 2026 15:34:03 GMT"/>
						<outline text="try {" created="Thu, 30 Apr 2026 15:39:37 GMT">
							<outline text="postRec = JSON.parse (jsontext)" created="Thu, 30 Apr 2026 15:39:41 GMT"/>
							<outline text="}" created="Thu, 30 Apr 2026 15:39:54 GMT"/>
							</outline>
						<outline text="catch (err) {" created="Thu, 30 Apr 2026 15:39:56 GMT">
							<outline text="const message = &quot;Can't add the post because the postRec doesn't parse properly.&quot;;" created="Thu, 30 Apr 2026 15:40:30 GMT"/>
							<outline text="callback ({message});" created="Thu, 30 Apr 2026 15:40:00 GMT"/>
							<outline text="return;" created="Thu, 30 Apr 2026 15:40:25 GMT"/>
							<outline text="}" created="Thu, 30 Apr 2026 15:40:23 GMT"/>
							</outline>
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't add the post because there is no user with email \&quot;&quot; + email + &quot;\&quot;.&quot;;"/>
									<outline text="console.log (&quot;newPost: &quot; + message);" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="console.log (&quot;newPost: userRec == &quot; + utils.jsonStringify (userRec)); //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="if (userRec.emailSecret !== code) {">
										<outline text="const message = &quot;Can't add the post because the authorization code is not correct.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="const permalinkCode = utils.getRandomPassword (8); //6/20/26 by DW -- commented" isComment="true"/>
										<outline text="const theNewItem = {">
											<outline text="title: postRec.title,"/>
											<outline text="description: linkifyUrls (postRec.description), //7/13/26 by CC -- #175"/>
											<outline text="description: postRec.description," isComment="true"/>
											<outline text="markdowntext: postRec.markdowntext, //6/3/26 by DW" created="Sun, 03 May 2026 15:49:18 GMT"/>
											<outline text="markdowntext: getMarkdownFromHtml (postRec.description), //5/3/26 by DW" isComment="true" created="Sun, 03 May 2026 15:49:18 GMT"/>
											<outline text="inReplyTo: postRec.inReplyTo,"/>
											<outline text="feedUrl: getFeedUrl (userRec.screenname),"/>
											<outline text="guid: getPermalinkUrl (userRec.screenname, permalinkCode), //6/20/26 by DW -- commented" isComment="true"/>
											<outline text="pubDate: new Date (),"/>
											<outline text="author: userRec.screenname, //5/4/26 by DW" created="Mon, 04 May 2026 13:46:19 GMT"/>
											<outline text="};"/>
											</outline>
										<outline text="addItem (theNewItem, function (err, itemRec) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="updateFeedsOnS3 (userRec, function (err, data) {">
													<outline text="if (err) {">
														<outline text="callback (err);"/>
														<outline text="}"/>
														</outline>
													<outline text="else {">
														<outline text="itemRec.guid = getPermalinkUrl (itemRec); //6/20/26 by DW"/>
														<outline text="callback (undefined, itemRec);"/>
														<outline text="}"/>
														</outline>
													<outline text="});"/>
													</outline>
												<outline text="updateReplyFeedsOnS3 (itemRec.inReplyTo, userRec.screenname); //7/8/26 by CC"/>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function updatePost (email, code, jsontext, callback) { //5/21/26 by DW">
						<outline text="Changes" isComment="true" created="Thu, 21 May 2026 13:21:51 GMT">
							<outline text="5/21/26; 9:21:53 AM by DW" created="Thu, 21 May 2026 13:21:52 GMT">
								<outline text="Wrote this so we can edit posts, but there's a ton of replication here. " created="Thu, 21 May 2026 13:21:53 GMT"/>
								<outline text="I added a note in daveToClaude.opml under today's date -- explaining how this is usually factored in my apps, and should be here." created="Thu, 21 May 2026 13:22:07 GMT"/>
								</outline>
							</outline>
						<outline text="console.log (&quot;updatePost: email == &quot; + email + &quot;, code == &quot; + code + &quot;, jsontext == &quot; + jsontext); " isComment="true" created="Sun, 10 May 2026 14:29:51 GMT"/>
						<outline text="var postRec;" created="Thu, 30 Apr 2026 15:34:03 GMT"/>
						<outline text="try {" created="Thu, 30 Apr 2026 15:39:37 GMT">
							<outline text="postRec = JSON.parse (jsontext)" created="Thu, 30 Apr 2026 15:39:41 GMT"/>
							<outline text="}" created="Thu, 30 Apr 2026 15:39:54 GMT"/>
							</outline>
						<outline text="catch (err) {" created="Thu, 30 Apr 2026 15:39:56 GMT">
							<outline text="const message = &quot;Can't update the post because the postRec doesn't parse properly.&quot;;" created="Thu, 30 Apr 2026 15:40:30 GMT"/>
							<outline text="callback ({message});" created="Thu, 30 Apr 2026 15:40:00 GMT"/>
							<outline text="return;" created="Thu, 30 Apr 2026 15:40:25 GMT"/>
							<outline text="}" created="Thu, 30 Apr 2026 15:40:23 GMT"/>
							</outline>
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't update the post because there is no user with email \&quot;&quot; + email + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="if (userRec.emailSecret !== code) {">
										<outline text="const message = &quot;Can't update the post because the authorization code is not correct.&quot;;"/>
										<outline text="console.log (&quot;updatePost: &quot; + message); " created="Sun, 10 May 2026 14:45:16 GMT"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="console.log (&quot;updatePost: userRec.id == &quot; + userRec.id); " isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
										<outline text="getItemById (userRec.screenname, postRec.id, function (err, existingItemRec) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="if (existingItemRec === undefined) {">
													<outline text="const message = &quot;Can't update the post because there is no item with id &quot; + postRec.id + &quot;.&quot;;"/>
													<outline text="callback ({message});"/>
													<outline text="}"/>
													</outline>
												<outline text="else {">
													<outline text="if (existingItemRec.author !== userRec.screenname) {">
														<outline text="const message = &quot;Can't update the post because it was written by a different user.&quot;;"/>
														<outline text="callback ({message});"/>
														<outline text="}"/>
														</outline>
													<outline text="else {">
														<outline text="postRec.description = linkifyUrls (postRec.description); //7/13/26 by CC -- #175"/>
														<outline text="updateItem (postRec, function (err, itemRec) {">
															<outline text="if (err) {">
																<outline text="callback (err);"/>
																<outline text="}"/>
																</outline>
															<outline text="else {">
																<outline text="updateFeedsOnS3 (userRec, function (err, data) {">
																	<outline text="if (err) {">
																		<outline text="callback (err);"/>
																		<outline text="}"/>
																		</outline>
																	<outline text="else {">
																		<outline text="callback (undefined, itemRec);"/>
																		<outline text="}"/>
																		</outline>
																	<outline text="});"/>
																	</outline>
																<outline text="updateReplyFeedsOnS3 (existingItemRec.inReplyToNum, userRec.screenname);"/>
																<outline text="}"/>
																</outline>
															<outline text="});"/>
															</outline>
														<outline text="}"/>
														</outline>
													<outline text="}"/>
													</outline>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="else {" isComment="true">
										<outline text="updateItem (postRec, function (err, itemRec) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="updateFeedsOnS3 (userRec, function (err, data) {">
													<outline text="if (err) {">
														<outline text="callback (err);"/>
														<outline text="}"/>
														</outline>
													<outline text="else {">
														<outline text="callback (undefined, itemRec);"/>
														<outline text="}"/>
														</outline>
													<outline text="});"/>
													</outline>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Fri, 12 Jun 2026 15:31:42 GMT"/>
					<outline text="function validateUser (email, code, what, callback) { //6/12/26 by DW">
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't &quot; + what + &quot; post because there is no user with email \&quot;&quot; + email + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="console.log (&quot;validateUser: userRec == &quot; + utils.jsonStringify (userRec)); " isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="if (userRec.emailSecret !== code) {">
										<outline text="const message = &quot;Can't &quot;+ what + &quot; because the authorization code is not correct.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="callback (undefined, userRec);" created="Fri, 12 Jun 2026 15:38:04 GMT"/>
										<outline text="}"/>
										</outline>
									<outline text="else {" isComment="true">
										<outline text="updateItem (postRec, function (err, itemRec) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="updateFeedsOnS3 (userRec, function (err, data) {">
													<outline text="if (err) {">
														<outline text="callback (err);"/>
														<outline text="}"/>
														</outline>
													<outline text="else {">
														<outline text="callback (undefined, itemRec);"/>
														<outline text="}"/>
														</outline>
													<outline text="});"/>
													</outline>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function userOwnsItem (userRec, idItem, what, callback) { //6/12/26 by DW" created="Fri, 12 Jun 2026 15:55:19 GMT">
						<outline text="getItemById (userRec.screenname, idItem, function (err, itemRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (itemRec === undefined) {">
									<outline text="const message = &quot;Can't &quot; + what + &quot; the post because there is no item with id &quot; + idItem + &quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="if (itemRec.author !== userRec.screenname) {">
										<outline text="const message = &quot;Can't &quot; + what + &quot; the post because it was written by a different user.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="callback (undefined, itemRec);"/>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}" created="Fri, 12 Jun 2026 15:55:33 GMT"/>
						</outline>
					<outline text="function deletePost (email, code, id, callback) { //6/12/26 by DW">
						<outline text="console.log (&quot;deletePost: id == &quot; + id);" isComment="true"/>
						<outline text="validateUser (email, code, &quot;delete&quot;, function (err, userRec) {" created="Fri, 12 Jun 2026 15:39:21 GMT">
							<outline text="if (err) {" created="Fri, 12 Jun 2026 15:39:43 GMT">
								<outline text="callback (err);" created="Fri, 12 Jun 2026 15:39:45 GMT"/>
								<outline text="}" created="Fri, 12 Jun 2026 15:39:49 GMT"/>
								</outline>
							<outline text="else {" created="Fri, 12 Jun 2026 15:39:49 GMT">
								<outline text="if (id === undefined) {">
									<outline text="const message = &quot;Can't delete the item because no id was provided.&quot;;" created="Fri, 12 Jun 2026 15:40:23 GMT"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="userOwnsItem (userRec, id, &quot;delete&quot;, function (err, itemRec) {" created="Fri, 12 Jun 2026 15:58:43 GMT">
										<outline text="if (err) {" created="Fri, 12 Jun 2026 15:59:22 GMT">
											<outline text="callback (err);" created="Fri, 12 Jun 2026 15:59:24 GMT"/>
											<outline text="}" created="Fri, 12 Jun 2026 15:59:27 GMT"/>
											</outline>
										<outline text="else {" created="Fri, 12 Jun 2026 15:59:28 GMT">
											<outline text="const sqltext = &quot;update items set flDeleted = 1 where id = &quot; + davesql.encode (id) + &quot;;&quot;;"/>
											<outline text="davesql.runSqltext (sqltext, function (err, result) {">
												<outline text="if (err) {">
													<outline text="callback (err);"/>
													<outline text="}"/>
													</outline>
												<outline text="else {">
													<outline text="if (result.affectedRows === 0) {">
														<outline text="const message = &quot;Can't delete the item because there is no item with id &quot; + id + &quot;.&quot;;"/>
														<outline text="callback ({message});"/>
														<outline text="}"/>
														</outline>
													<outline text="else {">
														<outline text="updateFeedsOnS3 (userRec, function (err, data) {">
															<outline text="if (err) {">
																<outline text="callback (err);"/>
																<outline text="}"/>
																</outline>
															<outline text="else {">
																<outline text="callback (undefined, itemRec);"/>
																<outline text="}"/>
																</outline>
															<outline text="});"/>
															</outline>
														<outline text="updateReplyFeedsOnS3 (itemRec.inReplyToNum, userRec.screenname);"/>
														<outline text="}"/>
														</outline>
													<outline text="}"/>
													</outline>
												<outline text="});"/>
												</outline>
											<outline text="}" created="Fri, 12 Jun 2026 15:59:30 GMT"/>
											</outline>
										<outline text="});" created="Fri, 12 Jun 2026 15:59:17 GMT"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}" created="Fri, 12 Jun 2026 15:39:51 GMT"/>
								</outline>
							<outline text="});" created="Fri, 12 Jun 2026 15:39:39 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Fri, 12 Jun 2026 15:31:44 GMT"/>
					<outline text="function bumpUserHits (screenname, callback) { //7/1/26 by CC">
						<outline text="Changes" isComment="true" created="Wed, 01 Jul 2026 14:34:57 GMT">
							<outline text="7/1/26; 10:35:01 AM by CC" created="Wed, 01 Jul 2026 14:34:59 GMT">
								<outline text="#122: count a hit for a user -- ctHits +1, ctHitsToday +1 within the same day (reset to 1 on a new day), whenLastHit = now. Call after any authenticated user action worth counting." created="Wed, 01 Jul 2026 14:35:02 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;update users set ctHits = ctHits + 1, ctHitsToday = case when date (whenLastHit) = date (now ()) then ctHitsToday + 1 else 1 end, whenLastHit = now () where screenname = &quot; + davesql.encode (screenname) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err) {">
							<outline text="if (err) {">
								<outline text="if (callback !== undefined) {" created="Wed, 01 Jul 2026 14:40:44 GMT">
									<outline text="callback (err);"/>
									<outline text="}" created="Wed, 01 Jul 2026 14:40:51 GMT"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (callback !== undefined) {" created="Wed, 01 Jul 2026 14:40:44 GMT">
									<outline text="callback (undefined);"/>
									<outline text="}" created="Wed, 01 Jul 2026 14:40:51 GMT"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function savePrefs (email, code, jsontext, callback) { //5/16/26 by DW" created="Sat, 16 May 2026 21:14:21 GMT">
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't set the prefs because there is no user with email \&quot;&quot; + email + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="console.log (&quot;savePrefs: screenname == &quot; + userRec.screenname); //6/9/26 by DW" isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="console.log (&quot;savePrefs: userRec == &quot; + utils.jsonStringify (userRec)); //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="if (userRec.emailSecret !== code) {">
										<outline text="const message = &quot;Can't set the prefs because the authorization code is not correct.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="const sqltext = &quot;update users set prefs = &quot; + davesql.encode (jsontext) + &quot; where screenname = &quot; + davesql.encode (userRec.screenname) + &quot;;&quot;;"/>
										<outline text="davesql.runSqltext (sqltext, function (err) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="bumpUserHits (userRec.screenname); //7/1/26 by DW"/>
												<outline text="callback (undefined);"/>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}" created="Sat, 16 May 2026 21:14:36 GMT"/>
						</outline>
					<outline text="function savePrefs (email, code, jsontext, callback) { //5/16/26 by DW" isComment="true" created="Sat, 16 May 2026 21:14:21 GMT">
						<outline text="getUserInfoByEmail (email, function (err, userRec) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (userRec === undefined) {">
									<outline text="const message = &quot;Can't set the prefs because there is no user with email \&quot;&quot; + email + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="console.log (&quot;savePrefs: screenname == &quot; + userRec.screenname); //6/9/26 by DW" isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="console.log (&quot;savePrefs: userRec == &quot; + utils.jsonStringify (userRec)); //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 14:45:16 GMT"/>
									<outline text="if (userRec.emailSecret !== code) {">
										<outline text="const message = &quot;Can't set the prefs because the authorization code is not correct.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="const sqltext = &quot;update users set prefs = &quot; + davesql.encode (jsontext) + &quot; where screenname = &quot; + davesql.encode (userRec.screenname) + &quot;;&quot;;"/>
										<outline text="davesql.runSqltext (sqltext, function (err) {">
											<outline text="if (err) {">
												<outline text="callback (err);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="callback (undefined);"/>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}" created="Sat, 16 May 2026 21:14:36 GMT"/>
						</outline>
					<outline text="function getThemes (callback) { //5/1/26 by DW" isComment="true" created="Fri, 01 May 2026 15:32:04 GMT">
						<outline text="console.log (&quot;getThemes&quot;);" created="Fri, 01 May 2026 15:43:52 GMT"/>
						<outline text="var opmltext;" created="Fri, 01 May 2026 15:48:13 GMT"/>
						<outline text="try {" created="Fri, 01 May 2026 15:48:28 GMT">
							<outline text="opmltext = fs.readFileSync (config.fnameThemes, &quot;utf8&quot;);" created="Fri, 01 May 2026 15:48:13 GMT"/>
							<outline text="}" created="Fri, 01 May 2026 15:48:30 GMT"/>
							</outline>
						<outline text="catch (err) {" created="Fri, 01 May 2026 15:48:32 GMT">
							<outline text="}" created="Fri, 01 May 2026 15:48:35 GMT"/>
							</outline>
						<outline text="" created="Fri, 01 May 2026 15:48:13 GMT"/>
						<outline text="" created="Fri, 01 May 2026 15:48:13 GMT"/>
						<outline text="" created="Fri, 01 May 2026 15:48:13 GMT"/>
						<outline text="fs.readFile (config.fnameThemes, function (err, opmltext) {" created="Fri, 01 May 2026 15:32:56 GMT">
							<outline text="if (err) {" created="Fri, 01 May 2026 15:34:26 GMT">
								<outline text="callback (err);" created="Fri, 01 May 2026 15:34:31 GMT"/>
								<outline text="}" created="Fri, 01 May 2026 15:34:34 GMT"/>
								</outline>
							<outline text="else {" created="Fri, 01 May 2026 15:34:35 GMT">
								<outline text="opml.parse (opmltext, function (err, theOutline) {" created="Tue, 25 Oct 2022 16:38:12 GMT">
									<outline text="if (err) {" created="Tue, 25 Oct 2022 16:38:37 GMT">
										<outline text="callback (err);" created="Tue, 25 Oct 2022 16:38:40 GMT"/>
										<outline text="}" created="Tue, 25 Oct 2022 16:38:45 GMT"/>
										</outline>
									<outline text="else {" created="Tue, 25 Oct 2022 16:38:46 GMT">
										<outline text="const theThemes = getThemesFromOutline ();" created="Fri, 01 May 2026 15:42:36 GMT"/>
										<outline text="callback (undefined, theThemes);" created="Fri, 01 May 2026 15:42:47 GMT"/>
										<outline text="}" created="Tue, 25 Oct 2022 16:39:00 GMT"/>
										</outline>
									<outline text="});" created="Tue, 25 Oct 2022 16:38:25 GMT"/>
									</outline>
