					<outline text="opmlS3Path: &quot;/scripting/rssnetwork/data/subs.opml&quot;," created="Thu, 23 Apr 2026 14:32:31 GMT"/>
					<outline text="opmlListUrl: &quot;https://data.rss.network/subs.opml&quot;," created="Thu, 23 Apr 2026 14:33:39 GMT"/>
					<outline text="" created="Sat, 25 Apr 2026 17:53:56 GMT"/>
					<outline text="urlFeedlandServer: &quot;https://feedland.social/&quot;," created="Sat, 25 Apr 2026 17:53:56 GMT"/>
					<outline text="urlFeedlandRedirect: &quot;https://feedland.social/?item=&quot;," created="Sun, 26 Apr 2026 14:41:34 GMT"/>
					<outline text="" created="Wed, 29 Apr 2026 13:57:20 GMT"/>
					<outline text="maxRecentItems: 100, //4/29/26 by DW" created="Wed, 29 Apr 2026 13:57:20 GMT"/>
					<outline text="" created="Sun, 17 May 2026 20:05:58 GMT"/>
					<outline text="urlExtrasOpml: &quot;https://feedland.social/opml?screenname=davewiner&amp;catname=davesources&quot;," created="Sun, 17 May 2026 20:05:58 GMT"/>
					<outline text="" created="Wed, 01 Jul 2026 21:44:31 GMT"/>
					<outline text="robotsText: &quot;User-agent: *\nDisallow: /getitembyguid\nDisallow: /getiteminfo\n&quot; //7/1/26 by DW"/>
					<outline text="robotsText: &quot;User-agent: *\nDisallow: /getitembyguid\n&quot; //7/1/26 by DW" isComment="true" created="Wed, 01 Jul 2026 21:44:32 GMT"/>
					<outline text="};"/>
					</outline>
				<outline text="" created="Thu, 09 Jul 2026 15:41:05 GMT"/>
				<outline text="//misc stuff" created="Sun, 26 Apr 2026 21:07:36 GMT">
					<outline text="function getExtrasList (callback) { //5/17/26 by DW" created="Sun, 17 May 2026 20:23:58 GMT">
						<outline text="opml.readOutline (config.urlExtrasOpml, function (err, theOutline) {" created="Tue, 25 Oct 2022 16:38:12 GMT">
							<outline text="if (err) {" created="Tue, 25 Oct 2022 16:38:37 GMT">
								<outline text="callback (err);" created="Tue, 25 Oct 2022 16:38:40 GMT"/>
								<outline text="}" created="Tue, 25 Oct 2022 16:38:45 GMT"/>
								</outline>
							<outline text="else {" created="Tue, 25 Oct 2022 16:38:46 GMT">
								<outline text="function notComment (node) {" created="Tue, 16 Nov 2021 16:57:39 GMT">
									<outline text="return (!utils.getBoolean (node.isComment));" created="Tue, 16 Nov 2021 16:58:00 GMT"/>
									<outline text="}" created="Tue, 16 Nov 2021 16:57:45 GMT"/>
									</outline>
								<outline text="var theList = new Array ();" created="Sun, 17 May 2026 20:37:54 GMT"/>
								<outline text="theOutline.opml.body.subs.forEach (function (item) {" created="Sun, 17 May 2026 20:37:54 GMT">
									<outline text="if (notComment (item)) {" created="Sun, 17 May 2026 20:41:04 GMT">
										<outline text="theList.push (item.xmlUrl);" created="Sun, 17 May 2026 20:39:15 GMT"/>
										<outline text="}" created="Sun, 17 May 2026 20:41:10 GMT"/>
										</outline>
									<outline text="});" created="Sun, 17 May 2026 20:39:00 GMT"/>
									</outline>
								<outline text="callback (undefined, theList);" created="Sun, 17 May 2026 20:24:49 GMT"/>
								<outline text="}" created="Tue, 25 Oct 2022 16:39:00 GMT"/>
								</outline>
							<outline text="});" created="Tue, 25 Oct 2022 16:38:25 GMT"/>
							</outline>
						<outline text="}" created="Sun, 17 May 2026 20:24:09 GMT"/>
						</outline>
					<outline text="function getMysqlVersion (callback) { //11/18/23 by DW" created="Sat, 18 Nov 2023 16:56:16 GMT">
						<outline text="const sqltext = &quot;select version () as version;&quot;;" created="Sun, 05 Nov 2023 12:30:42 GMT"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="var theVersion = undefined;" created="Sat, 18 Nov 2023 17:05:16 GMT"/>
							<outline text="if (err) {" created="Sun, 26 Apr 2026 21:11:57 GMT">
								<outline text="console.log (&quot;getMysqlVersion: err.message == &quot; + err.message);" created="Sun, 26 Apr 2026 21:12:11 GMT"/>
								<outline text="}" created="Sun, 26 Apr 2026 21:12:01 GMT"/>
								</outline>
							<outline text="else {" created="Sun, 26 Apr 2026 21:12:02 GMT">
								<outline text="if (result.length == 0) {" created="Sun, 05 Nov 2023 12:32:52 GMT">
									<outline text="console.log (&quot;getMysqlVersion: result.length == &quot; + result.length);" created="Sun, 26 Apr 2026 21:12:11 GMT"/>
									<outline text="}" created="Sun, 05 Nov 2023 12:33:03 GMT"/>
									</outline>
								<outline text="else {" created="Sun, 26 Apr 2026 21:13:02 GMT">
									<outline text="theVersion = result [0].version;" created="Sat, 18 Nov 2023 17:06:11 GMT"/>
									<outline text="console.log (&quot;getMysqlVersion: theVersion == &quot; + theVersion);" created="Sun, 26 Apr 2026 21:12:11 GMT"/>
									<outline text="}" created="Sun, 26 Apr 2026 21:13:03 GMT"/>
									</outline>
								<outline text="}" created="Sun, 26 Apr 2026 21:12:04 GMT"/>
								</outline>
							<outline text="callback (undefined, theVersion);" created="Sat, 18 Nov 2023 17:08:19 GMT"/>
							<outline text="});"/>
							</outline>
						<outline text="}" created="Sat, 18 Nov 2023 16:56:24 GMT"/>
						</outline>
					<outline text="function getMarkdownFromHtml (htmltext) { //3/28/26 by DW" created="Thu, 25 Apr 2024 12:54:39 GMT">
						<outline text="const myTurndown = new turndown ();" created="Mon, 10 Nov 2025 16:21:46 GMT"/>
						<outline text="const markdowntext = myTurndown.turndown (htmltext);"/>
						<outline text="return (markdowntext);" created="Thu, 25 Apr 2024 12:55:59 GMT"/>
						<outline text="}" created="Thu, 25 Apr 2024 12:54:51 GMT"/>
						</outline>
					<outline text="function notifySocketSubscribers (verb, payload, callbackToQualify) { //6/21/26 by CC -- broadcast inline to our own socket clients; modeled on feedland.js">
						<outline text="if (config.flWebsocketEnabled) {">
							<outline text="const flPayloadIsString = false;" created="Sun, 21 Jun 2026 12:40:32 GMT"/>
							<outline text="console.log (&quot;notifySocketSubscribers: verb == &quot; + verb + &quot;, payload == &quot; + utils.jsonStringify (payload)); //6/24/26 by DW" isComment="true" created="Wed, 24 Jun 2026 15:27:03 GMT"/>
							<outline text="daveappserver.notifySocketSubscribers (verb, payload, flPayloadIsString, callbackToQualify);"/>
							<outline text="}"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getCommentsFeedUrl (screenname, idPost) { //7/8/26 by CC">
						<outline text="return (config.rssFeedUrl + screenname + &quot;/comments/&quot; + idPost + &quot;.xml&quot;);"/>
						<outline text="}"/>
						</outline>
					<outline text="function linkifyUrls (htmltext) { //7/13/26 by CC">
						<outline text="Changes" isComment="true" created="Mon, 13 Jul 2026 12:59:54 GMT">
							<outline text="7/13/26; 8:59:58 AM by CC" created="Mon, 13 Jul 2026 12:59:57 GMT">
								<outline text="#175, from donpark's post 248. Bare URLs in post text become links at save time. Autolinker walks the HTML and only linkifies plain text, so URLs already inside an anchor, or in an attribute like an img src, are never touched. stripPrefix false keeps the link text exactly as the writer typed it. Email addresses and phone numbers deliberately not linked -- the ask was URLs." created="Mon, 13 Jul 2026 12:59:58 GMT"/>
								</outline>
							</outline>
						<outline text="if (htmltext === undefined) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="else {" created="Mon, 13 Jul 2026 12:59:02 GMT">
							<outline text="const theLinker = new autolinker ({">
								<outline text="urls: true,"/>
								<outline text="email: false,"/>
								<outline text="phone: false,"/>
								<outline text="stripPrefix: false,"/>
								<outline text="stripTrailingSlash: false,"/>
								<outline text="newWindow: false"/>
								<outline text="});"/>
								</outline>
							<outline text="return (theLinker.link (htmltext));"/>
							<outline text="}" created="Mon, 13 Jul 2026 12:59:03 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					</outline>
				<outline text="//sql code" created="Sun, 26 Apr 2026 21:28:19 GMT">
					<outline text="function convertString (theString) {">
						<outline text="if ((theString === null) || (theString === undefined)) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="if (theString.length === 0) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="return (theString);"/>
						<outline text="}"/>
						</outline>
					<outline text="function convertNumber (theNumber) {">
						<outline text="if ((theNumber === null) || (theNumber === undefined)) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="return (theNumber);"/>
						<outline text="}"/>
						</outline>
					<outline text="function convertDate (theDate) {">
						<outline text="if ((theDate === null) || (theDate === undefined)) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="const d = new Date (theDate);"/>
						<outline text="if (isNaN (d)) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="return (d);"/>
						<outline text="}"/>
						</outline>
					<outline text="function convertJson (jsontext) {" created="Sat, 16 May 2026 20:52:44 GMT">
						<outline text="if ((jsontext === null) || (jsontext === undefined)) {">
							<outline text="return (undefined);"/>
							<outline text="}"/>
							</outline>
						<outline text="const jstruct = JSON.parse (jsontext);" created="Sat, 16 May 2026 20:53:42 GMT"/>
						<outline text="return (jstruct);" created="Sat, 16 May 2026 20:54:08 GMT"/>
						<outline text="}" created="Sat, 16 May 2026 20:52:51 GMT"/>
						</outline>
					<outline text="function convertUser (theUser) {">
						<outline text="return ({">
							<outline text="screenname: convertString (theUser.screenname),"/>
							<outline text="emailAddress: convertString (theUser.emailAddress),"/>
							<outline text="emailSecret: convertString (theUser.emailSecret),"/>
							<outline text="imageUrl:  convertString (theUser.imageUrl), //5/4/26 by DW" created="Mon, 04 May 2026 13:11:50 GMT"/>
							<outline text="whenCreated: convertDate (theUser.whenCreated),"/>
							<outline text="whenUpdated: convertDate (theUser.whenUpdated),"/>
							<outline text="prefs: convertJson (theUser.prefs) //5/16/26 by DW" created="Sat, 16 May 2026 20:46:19 GMT"/>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function convertItem (theItem) { ">
						<outline text="Changes" isComment="true" created="Wed, 29 Apr 2026 14:27:26 GMT">
							<outline text="6/8/26; 12:26:41 PM by DW" created="Mon, 08 Jun 2026 16:26:41 GMT">
								<outline text="Author's value depends on whether it's a feed title and we have a new screenitem value. " created="Mon, 08 Jun 2026 16:26:42 GMT"/>
								</outline>
							<outline text="5/15/26; 6:35:05 PM by DW" created="Fri, 15 May 2026 22:35:05 GMT">
								<outline text="inReplyToValue is a url, not a number, but in the database it's the id of a post in the database." created="Fri, 15 May 2026 22:35:06 GMT"/>
								<outline text="so we generate a url" created="Fri, 15 May 2026 22:35:50 GMT"/>
								</outline>
							<outline text="4/29/26; 10:27:29 AM by DW" created="Wed, 29 Apr 2026 14:27:28 GMT">
								<outline text="Don't pass through undefined values." created="Wed, 29 Apr 2026 14:27:29 GMT"/>
								</outline>
							</outline>
						<outline text="console.log (&quot;convertItem: theItem == &quot; + utils.jsonStringify (theItem)); //6/8/26 by DW" isComment="true" created="Mon, 08 Jun 2026 15:10:31 GMT"/>
						<outline text="function getAuthor (theItem) { //6/8/26 by DW">
							<outline text="const feedTitle = convertString (theItem.feedTitle);"/>
							<outline text="if (feedTitle !== undefined) {">
								<outline text="return (feedTitle);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {" created="Mon, 08 Jun 2026 16:25:24 GMT">
								<outline text="return (convertString (theItem.author));"/>
								<outline text="}" created="Mon, 08 Jun 2026 16:25:26 GMT"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text="const jstruct = {">
							<outline text="id: convertNumber (theItem.id),"/>
							<outline text="feedUrl: convertString (theItem.feedUrl),"/>
							<outline text="guid: getPermalinkUrl (theItem), //6/20/26 by DW" created="Sat, 20 Jun 2026 15:08:35 GMT"/>
							<outline text="guid: convertString (theItem.guid)," isComment="true"/>
							<outline text="title: convertString (theItem.title),"/>
							<outline text="inReplyToNum: convertNumber (theItem.inReplyTo), //4/30/26 by DW"/>
							<outline text="inReplyToUrl: getInReplyToPermalink (convertNumber (theItem.inReplyTo)), //7/5/26 by DW"/>
							<outline text="inReplyToUrl: getInReplyToPermalink (theItem.inReplyTo), //5/15/26 by DW" isComment="true"/>
							<outline text="link: convertString (theItem.link),"/>
							<outline text="description: convertString (theItem.description),"/>
							<outline text="pubDate: convertDate (theItem.pubDate),"/>
							<outline text="enclosureUrl: convertString (theItem.enclosureUrl),"/>
							<outline text="enclosureType: convertString (theItem.enclosureType),"/>
							<outline text="enclosureLength: convertNumber (theItem.enclosureLength),"/>
							<outline text="whenCreated: convertDate (theItem.whenCreated),"/>
							<outline text="whenUpdated: convertDate (theItem.whenUpdated),"/>
							<outline text="markdowntext: convertString (theItem.markdowntext),"/>
							<outline text="outlineJsontext: convertString (theItem.outlineJsontext),"/>
							<outline text="imageUrl: convertString (theItem.imageUrl), //5/4/26 by DW" created="Mon, 04 May 2026 13:44:24 GMT"/>
							<outline text="author: getAuthor (theItem), //6/8/26 by DW"/>
							<outline text="author: convertString (theItem.author), //5/4/26 by DW" isComment="true" created="Sat, 02 May 2026 22:15:42 GMT"/>
							<outline text="screenname: convertString (theItem.author), //account id -- 6/8/26"/>
							<outline text="feedLink: convertString (theItem.feedLink), //6/8/26"/>
							<outline text="feedDescription: convertString (theItem.feedDescription), //6/8/26"/>
							<outline text="flDeleted: utils.getBoolean (theItem.flDeleted), //6/12/26 by DW" created="Fri, 12 Jun 2026 16:41:58 GMT"/>
							<outline text="ctLikes: convertNumber (theItem.ctLikes), //6/24/26 by DW"/>
							<outline text="flLiked: utils.getBoolean (theItem.flLiked), //6/24/26 by DW"/>
							<outline text="inReplyToAuthor: convertString (theItem.inReplyToAuthor), //6/30/26 by DW" created="Tue, 30 Jun 2026 22:30:52 GMT"/>
							<outline text="ctReplies: convertNumber (theItem.ctReplies), //7/3/26 by CC"/>
							<outline text="}"/>
							</outline>
						<outline text="var theConvertedItem = new Object ();" created="Wed, 29 Apr 2026 14:26:13 GMT"/>
						<outline text="for (var x in jstruct) {" created="Wed, 29 Apr 2026 14:28:30 GMT">
							<outline text="if (jstruct [x] !== undefined) {" created="Wed, 29 Apr 2026 14:26:54 GMT">
								<outline text="theConvertedItem [x] = jstruct [x];" created="Wed, 29 Apr 2026 14:27:01 GMT"/>
								<outline text="}" created="Wed, 29 Apr 2026 14:27:00 GMT"/>
								</outline>
							<outline text="}" created="Wed, 29 Apr 2026 14:28:37 GMT"/>
							</outline>
						<outline text="console.log (&quot;convertItem: jstruct == &quot; + utils.jsonStringify (jstruct)); //6/8/26 by DW" isComment="true" created="Mon, 08 Jun 2026 15:10:31 GMT"/>
						<outline text="return (theConvertedItem);" created="Wed, 29 Apr 2026 14:27:16 GMT"/>
						<outline text="}"/>
						</outline>
					<outline text="function getUserInfoByScreenname (screenname, callback) {">
						<outline text="const sqltext = &quot;select * from users where screenname = &quot; + davesql.encode (screenname) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (result.length === 0) {">
									<outline text="callback (undefined, undefined);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, convertUser (result [0]));"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getUserInfoByEmail (email, callback) {">
						<outline text="const sqltext = &quot;select * from users where emailAddress = &quot; + davesql.encode (email) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (result.length === 0) {">
									<outline text="callback (undefined, undefined);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, convertUser (result [0]));"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function addUser (userRec, callback) {">
						<outline text="const theValues = {">
							<outline text="screenname: userRec.screenname,"/>
							<outline text="emailAddress: userRec.emailAddress,"/>
							<outline text="emailSecret: userRec.emailSecret"/>
							<outline text="};"/>
							</outline>
						<outline text="const sqltext = &quot;insert into users &quot; + davesql.encodeValues (theValues);"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="updateSubscriptionListOnS3 (); //6/23/26 by DW"/>
								<outline text="callback (undefined, userRec);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function updateUser (userRec, callback) {">
						<outline text="function encode (theValue) {">
							<outline text="return (davesql.encode (theValue));"/>
							<outline text="}"/>
							</outline>
						<outline text="console.log (&quot;updateUser: userRec.screenname == &quot; + userRec.screenname); //5/10/26 by DW" created="Sun, 10 May 2026 15:29:09 GMT"/>
						<outline text="const sqltext = &quot;update users set emailAddress = &quot; + encode (userRec.emailAddress) + &quot;, emailSecret = &quot; + encode (userRec.emailSecret) + &quot; where screenname = &quot; + encode (userRec.screenname) + &quot;;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (result.affectedRows === 0) {">
									<outline text="const message = &quot;Can't update the user because there is no user with screenname \&quot;&quot; + userRec.screenname + &quot;\&quot;.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, userRec);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getAllScreennames (callback) {">
						<outline text="const sqltext = &quot;select screenname from users;&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var screennames = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="screennames.push (row.screenname);"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, screennames);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function addItem (itemRec, callback) {">
						<outline text="const theValues = {">
							<outline text="feedUrl: itemRec.feedUrl,"/>
							<outline text="guid: itemRec.guid, //6/20/26 by DW -- commented" isComment="true"/>
							<outline text="title: itemRec.title,"/>
							<outline text="link: itemRec.link,"/>
							<outline text="description: itemRec.description,"/>
							<outline text="inReplyTo: itemRec.inReplyTo, //4/30/26 by DW"/>
							<outline text="pubDate: itemRec.pubDate,"/>
							<outline text="enclosureUrl: itemRec.enclosureUrl,"/>
							<outline text="enclosureType: itemRec.enclosureType,"/>
							<outline text="enclosureLength: itemRec.enclosureLength,"/>
							<outline text="markdowntext: itemRec.markdowntext,"/>
							<outline text="outlineJsontext: itemRec.outlineJsontext,"/>
							<outline text="author: itemRec.author, //5/4/26 by DW"/>
							<outline text="};"/>
							</outline>
						<outline text="console.log (&quot;addItem: theValues == &quot; + utils.jsonStringify (theValues)); //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 14:29:51 GMT"/>
						<outline text="const sqltext = &quot;insert into items &quot; + davesql.encodeValues (theValues);"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="itemRec.id = result.insertId;"/>
								<outline text="callback (undefined, itemRec);"/>
								<outline text="getItemByGuid (undefined, getPermalinkUrl (itemRec), function (err, item) { //6/21/26 by CC">
									<outline text="if (err) {" created="Sun, 21 Jun 2026 12:50:06 GMT">
										<outline text="console.log (&quot;addItem: err.message == &quot; + err.message);" created="Sun, 21 Jun 2026 12:52:23 GMT"/>
										<outline text="}" created="Sun, 21 Jun 2026 12:50:46 GMT"/>
										</outline>
									<outline text="else {" created="Sun, 21 Jun 2026 12:50:47 GMT">
										<outline text="if (item !== undefined) {">
											<outline text="notifySocketSubscribers (&quot;newItem&quot;, {item});"/>
											<outline text="}"/>
											</outline>
										<outline text="}" created="Sun, 21 Jun 2026 12:50:48 GMT"/>
										</outline>
									<outline text="});"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function updateItem (itemRec, callback) {">
						<outline text="console.log (&quot;updateItem: itemRec.id == &quot; + itemRec.id);" isComment="true" created="Thu, 21 May 2026 14:20:43 GMT"/>
						<outline text="if (itemRec.id === undefined) {">
							<outline text="callback ({message: &quot;Can't update the item because no id was provided.&quot;});"/>
							<outline text="}" created="Thu, 21 May 2026 14:21:17 GMT"/>
							</outline>
						<outline text="else {" created="Thu, 21 May 2026 14:21:18 GMT">
							<outline text="var setClause = &quot;&quot;;"/>
							<outline text="function add (fieldname, theValue) {">
								<outline text="if (theValue !== undefined) {">
									<outline text="if (setClause.length &gt; 0) {">
										<outline text="setClause += &quot;, &quot;;"/>
										<outline text="}"/>
										</outline>
									<outline text="setClause += fieldname + &quot; = &quot; + davesql.encode (theValue);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="add (&quot;feedUrl&quot;, itemRec.feedUrl);"/>
							<outline text="add (&quot;guid&quot;, itemRec.guid); //6/20/26 by DW -- commented" isComment="true"/>
							<outline text="add (&quot;title&quot;, itemRec.title);"/>
							<outline text="add (&quot;link&quot;, itemRec.link);"/>
							<outline text="add (&quot;description&quot;, itemRec.description);"/>
							<outline text="add (&quot;inReplyTo&quot;, itemRec.inReplyTo);"/>
							<outline text="add (&quot;pubDate&quot;, itemRec.pubDate);"/>
							<outline text="add (&quot;enclosureUrl&quot;, itemRec.enclosureUrl);"/>
							<outline text="add (&quot;enclosureType&quot;, itemRec.enclosureType);"/>
							<outline text="add (&quot;enclosureLength&quot;, itemRec.enclosureLength);"/>
							<outline text="add (&quot;markdowntext&quot;, itemRec.markdowntext);"/>
							<outline text="add (&quot;outlineJsontext&quot;, itemRec.outlineJsontext);"/>
							<outline text="add (&quot;author&quot;, itemRec.author);"/>
							<outline text="if (setClause.length === 0) {">
								<outline text="callback ({message: &quot;Can't update the item because no fields were provided.&quot;});"/>
								<outline text="return;"/>
								<outline text="}"/>
								</outline>
							<outline text="const sqltext = &quot;update items set &quot; + setClause + &quot; where id = &quot; + davesql.encode (itemRec.id) + &quot;;&quot;;"/>
							<outline text="davesql.runSqltext (sqltext, function (err, result) {">
								<outline text="if (err) {">
									<outline text="callback (err);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="if (result.affectedRows === 0) {">
										<outline text="callback ({message: &quot;Can't update the item because there is no item with id &quot; + itemRec.id + &quot;.&quot;});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="callback (undefined, itemRec);"/>
										<outline text="getItemByGuid (undefined, getPermalinkUrl (itemRec), function (err, item) { //6/21/26 by CC -- broadcast the edit to socket clients">
											<outline text="if (err) {">
												<outline text="console.log (&quot;updateItem: err.message == &quot; + err.message);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="if (item !== undefined) {">
													<outline text="notifySocketSubscribers (&quot;updatedItem&quot;, {item});"/>
													<outline text="}"/>
													</outline>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="}" created="Thu, 21 May 2026 14:21:20 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getRecentUserItems (screenname, feedUrl, maxCt, callback) {">
						<outline text="Changes" isComment="true" created="Wed, 24 Jun 2026 21:04:16 GMT">
							<outline text="6/24/26; 5:04:20 PM by DW" created="Wed, 24 Jun 2026 21:04:19 GMT">
								<outline text="New param, screenname, which says which user this list is being assembled for. " created="Wed, 24 Jun 2026 21:04:20 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; and (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; and (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; and (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true" created="Wed, 24 Jun 2026 21:06:52 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; and (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true" created="Fri, 12 Jun 2026 15:21:50 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true" created="Mon, 08 Jun 2026 16:43:48 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true" created="Mon, 08 Jun 2026 16:21:25 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.imageUrl from items left join users on users.screenname = items.author where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.imageUrl from items left join users on users.screenname = items.screenname where items.feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select * from items where feedUrl = &quot; + davesql.encode (feedUrl) + &quot; order by pubDate desc limit &quot; + maxCt + &quot;;&quot;;" isComment="true"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var items = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="items.push (convertItem (row));"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, items);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getRecentItems (screenname, maxCt, callback) { //4/29/26 by DW">
						<outline text="Changes" isComment="true" created="Wed, 24 Jun 2026 21:04:16 GMT">
							<outline text="6/24/26; 5:04:20 PM by DW" created="Wed, 24 Jun 2026 21:04:19 GMT">
								<outline text="New param, screenname, which says which user this list is being assembled for. " created="Wed, 24 Jun 2026 21:04:20 GMT"/>
								</outline>
							</outline>
						<outline text="if (maxCt === undefined) {" created="Wed, 29 Apr 2026 22:22:03 GMT">
							<outline text="maxCt = config.maxRecentItems;" created="Wed, 29 Apr 2026 13:58:46 GMT"/>
							<outline text="}" created="Wed, 29 Apr 2026 22:22:12 GMT"/>
							</outline>
						<outline text="else {" created="Wed, 29 Apr 2026 22:22:18 GMT">
							<outline text="maxCt = Number (maxCt); " created="Wed, 29 Apr 2026 22:21:28 GMT"/>
							<outline text="if (maxCt &gt; config.maxRecentItems) {" created="Wed, 29 Apr 2026 22:22:30 GMT">
								<outline text="maxCt = config.maxRecentItems;" created="Wed, 29 Apr 2026 13:58:46 GMT"/>
								<outline text="}" created="Wed, 29 Apr 2026 22:22:38 GMT"/>
								</outline>
							<outline text="}" created="Wed, 29 Apr 2026 22:22:20 GMT"/>
							</outline>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies from items left join users on users.screenname = items.author where (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked from items left join users on users.screenname = items.author where (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true" created="Wed, 24 Jun 2026 21:03:58 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author where (items.flDeleted is null or items.flDeleted = 0) order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true" created="Fri, 12 Jun 2026 15:22:19 GMT"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle from items left join users on users.screenname = items.author order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl from items left join users on users.screenname = items.author order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.imageUrl from items left join users on users.screenname = items.author order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.imageUrl from items left join users on users.screenname = items.screenname order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select * from items order by pubDate desc limit &quot; + davesql.encode (maxCt) + &quot;;&quot;;" isComment="true"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var items = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="items.push (convertItem (row));"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, items);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getItemById (screenname, id, callback) { //6/4/26 by Claude">
						<outline text="Changes" isComment="true" created="Wed, 24 Jun 2026 21:04:16 GMT">
							<outline text="6/24/26; 5:04:20 PM by DW" created="Wed, 24 Jun 2026 21:04:19 GMT">
								<outline text="New param, screenname, which says which user this list is being assembled for. " created="Wed, 24 Jun 2026 21:04:20 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select items.*, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items where id = &quot; + davesql.encode (id) + &quot;;&quot;;"/>
						<outline text="const sqltext = &quot;select items.*, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies from items where id = &quot; + davesql.encode (id) + &quot;;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked from items where id = &quot; + davesql.encode (id) + &quot;;&quot;;" isComment="true" created="Wed, 24 Jun 2026 21:09:18 GMT"/>
						<outline text="const sqltext = &quot;select * from items where id = &quot; + davesql.encode (id) + &quot;;&quot;;" isComment="true"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (result.length === 0) {">
									<outline text="callback (undefined, undefined);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="callback (undefined, convertItem (result [0]));"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getItemByGuid (screenname, guid, callback) { //6/8/26 by DW">
						<outline text="Changes" isComment="true" created="Wed, 24 Jun 2026 21:04:16 GMT">
							<outline text="7/7/26; 10:36:35 AM by CC" created="Tue, 07 Jul 2026 14:36:34 GMT">
								<outline text="Don't server contents of deleted posts. " created="Tue, 07 Jul 2026 14:36:51 GMT"/>
								<outline text="Archive old versions of SQL code." created="Tue, 07 Jul 2026 14:37:08 GMT">
									<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where items.id = &quot; + davesql.encode (theId) + &quot;;&quot;;"/>
									<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies from items left join users on users.screenname = items.author where items.id = &quot; + davesql.encode (theId) + &quot;;&quot;;" isComment="true"/>
									<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked from items left join users on users.screenname = items.author where items.id = &quot; + davesql.encode (theId) + &quot;;&quot;;" isComment="true" created="Wed, 24 Jun 2026 21:11:34 GMT"/>
									<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author where items.id = &quot; + davesql.encode (theId) + &quot;;&quot;;" isComment="true"/>
									<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription from items left join users on users.screenname = items.author where items.guid = &quot; + davesql.encode (guid) + &quot;;&quot;;" isComment="true"/>
									<outline text="const sqltext = &quot;select * from items where guid = &quot; + davesql.encode (guid) + &quot;;&quot;;" isComment="true"/>
									</outline>
								</outline>
							<outline text="6/29/26; 8:37:29 AM by DW" created="Mon, 29 Jun 2026 12:37:29 GMT">
								<outline text="Don't crash if guid is undefined." created="Mon, 29 Jun 2026 12:37:30 GMT"/>
								</outline>
							<outline text="6/24/26; 5:04:20 PM by DW" created="Wed, 24 Jun 2026 21:04:19 GMT">
								<outline text="New param, screenname, which says which user this list is being assembled for. " created="Wed, 24 Jun 2026 21:04:20 GMT"/>
								</outline>
							</outline>
						<outline text="if (guid == undefined) {" created="Mon, 29 Jun 2026 12:37:45 GMT">
							<outline text="const message = &quot;Can't get the item record because the GUID param is undefined.&quot;;" created="Mon, 29 Jun 2026 12:43:20 GMT"/>
							<outline text="console.log (&quot;getItemByGuid: &quot; + message);" created="Mon, 29 Jun 2026 12:44:34 GMT"/>
							<outline text="console.log (&quot;getItemByGuid: screenname == &quot; + screenname + &quot;, guid == &quot; + guid);" created="Mon, 29 Jun 2026 12:44:34 GMT"/>
							<outline text="callback ({message});" created="Mon, 29 Jun 2026 12:41:57 GMT"/>
							<outline text="}" created="Mon, 29 Jun 2026 12:37:55 GMT"/>
							</outline>
						<outline text="else {" created="Mon, 29 Jun 2026 12:37:55 GMT">
							<outline text="const theId = utils.stringNthField (guid, &quot;=&quot;, 2)" created="Sat, 20 Jun 2026 15:19:08 GMT"/>
							<outline text="const sqltext = `">
								<outline text="select">
									<outline text="items.*,"/>
									<outline text="users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl,"/>
									<outline text="users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle,"/>
									<outline text="users.prefs -&gt;&gt; '$.myFeedLink' as feedLink,"/>
									<outline text="users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription,"/>
									<outline text="(select count(*) from likes where likes.itemId = items.id) as ctLikes,"/>
									<outline text="(select count(*) from likes where likes.itemId = items.id and likes.screenname = ${davesql.encode (screenname)}) as flLiked,"/>
									<outline text="(select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies,"/>
									<outline text="(select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author)">
										<outline text="from items i2"/>
										<outline text="left join users u2 on u2.screenname = i2.author"/>
										<outline text="where i2.id = items.inReplyTo) as inReplyToAuthor"/>
										</outline>
									</outline>
								<outline text="from items"/>
								<outline text="left join users on users.screenname = items.author"/>
								<outline text="where items.id = ${davesql.encode (theId)};"/>
								<outline text="`;"/>
								</outline>
							<outline text="davesql.runSqltext (sqltext, function (err, result) {">
								<outline text="if (err) {">
									<outline text="callback (err);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="if (result.length === 0) {">
										<outline text="callback (undefined, undefined);"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="const itemRec = convertItem (result [0]);"/>
										<outline text="if (itemRec.flDeleted) { //7/7/26 by CC">
											<outline text="const message = &quot;Can't view the post because it has been deleted.&quot;;"/>
											<outline text="callback ({message});"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="callback (undefined, itemRec);"/>
											<outline text="}"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="}" created="Mon, 29 Jun 2026 12:37:57 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getItemAndReplies (screenname, idParent, callback) { //6/30/26 by CC">
						<outline text="Changes" isComment="true" created="Tue, 30 Jun 2026 21:29:02 GMT">
							<outline text="6/30/26; 5:29:04 PM by DW" created="Tue, 30 Jun 2026 21:29:03 GMT">
								<outline text="#121: the parent post plus its direct replies, so a reply reached by its own link can show its context" created="Tue, 30 Jun 2026 21:29:04 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select count(*) from items c where c.inReplyTo = items.id and (c.flDeleted is null or c.flDeleted = 0)) as ctReplies, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where (items.id = &quot; + davesql.encode (idParent) + &quot; or items.inReplyTo = &quot; + davesql.encode (idParent) + &quot;) and (items.flDeleted is null or items.flDeleted = 0) order by pubDate asc;&quot;;"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select coalesce (nullif (u2.prefs -&gt;&gt; '$.myFeedTitle', ''), i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where (items.id = &quot; + davesql.encode (idParent) + &quot; or items.inReplyTo = &quot; + davesql.encode (idParent) + &quot;) and (items.flDeleted is null or items.flDeleted = 0) order by pubDate asc;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked, (select coalesce (u2.prefs -&gt;&gt; '$.myFeedTitle', i2.author) from items i2 left join users u2 on u2.screenname = i2.author where i2.id = items.inReplyTo) as inReplyToAuthor from items left join users on users.screenname = items.author where (items.id = &quot; + davesql.encode (idParent) + &quot; or items.inReplyTo = &quot; + davesql.encode (idParent) + &quot;) and (items.flDeleted is null or items.flDeleted = 0) order by pubDate asc;&quot;;" isComment="true"/>
						<outline text="const sqltext = &quot;select items.*, users.prefs -&gt;&gt; '$.myAvatarImageUrl' as imageUrl, users.prefs -&gt;&gt; '$.myFeedTitle' as feedTitle, users.prefs -&gt;&gt; '$.myFeedLink' as feedLink, users.prefs -&gt;&gt; '$.myFeedDescription' as feedDescription, (select count(*) from likes where likes.itemId = items.id) as ctLikes, (select count(*) from likes where likes.itemId = items.id and likes.screenname = &quot; + davesql.encode (screenname) + &quot;) as flLiked from items left join users on users.screenname = items.author where (items.id = &quot; + davesql.encode (idParent) + &quot; or items.inReplyTo = &quot; + davesql.encode (idParent) + &quot;) and (items.flDeleted is null or items.flDeleted = 0) order by pubDate asc;&quot;;" isComment="true"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="var items = new Array ();"/>
								<outline text="result.forEach (function (row) {">
									<outline text="items.push (convertItem (row));"/>
									<outline text="});"/>
									</outline>
								<outline text="callback (undefined, items);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="" created="Sun, 26 Apr 2026 21:54:10 GMT"/>
					</outline>
				<outline text="//feeds" created="Wed, 22 Apr 2026 14:32:22 GMT">
					<outline text="function backfillCommentsFeeds () { //7/8/26 by DW">
						<outline text="Changes" isComment="true" created="Wed, 08 Jul 2026 17:18:00 GMT">
							<outline text="7/8/26; 1:18:05 PM by DW" created="Wed, 08 Jul 2026 17:18:04 GMT">
								<outline text="One-time backfill: publishes a comments feed for every existing post that has live replies, so the feedUrls the feeds now advertise all resolve. The join skips deleted parents and deleted replies. Safe to run more than once " created="Wed, 08 Jul 2026 17:18:05 GMT"/>
								</outline>
							</outline>
						<outline text="const sqltext = &quot;select distinct i.inReplyTo from items i join items p on p.id = i.inReplyTo where i.inReplyTo is not null and (i.flDeleted is null or i.flDeleted = 0) and (p.flDeleted is null or p.flDeleted = 0);&quot;;"/>
						<outline text="davesql.runSqltext (sqltext, function (err, result) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;backfillCommentsFeeds: err.message == &quot; + err.message);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="console.log (&quot;backfillCommentsFeeds: publishing &quot; + result.length + &quot; comments feeds.&quot;);"/>
								<outline text="result.forEach (function (row) {">
									<outline text="console.log (&quot;backfillCommentsFeeds: row.inReplyTo == &quot; + row.inReplyTo);" created="Wed, 08 Jul 2026 17:22:27 GMT"/>
									<outline text="publishCommentsFeed (row.inReplyTo);"/>
									<outline text="});"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getFeedUrl (screenname) { //4/22/26 by DW" created="Wed, 22 Apr 2026 17:14:20 GMT">
						<outline text="const relpath = screenname + &quot;/&quot; + config.rssFilename;" created="Wed, 22 Apr 2026 14:48:42 GMT"/>
						<outline text="const feedUrl = config.rssFeedUrl + relpath;" created="Wed, 22 Apr 2026 14:48:01 GMT"/>
						<outline text="return (feedUrl);" created="Wed, 22 Apr 2026 17:15:15 GMT"/>
						<outline text="}" created="Wed, 22 Apr 2026 17:14:34 GMT"/>
						</outline>
					<outline text="function getDefaultHeadElements () { //6/3/26 by DW " created="Wed, 03 Jun 2026 21:17:50 GMT">
						<outline text="const headElements = {" created="Wed, 03 Jun 2026 21:04:57 GMT">
							<outline text="language: config.rssLanguage, " created="Wed, 03 Jun 2026 21:05:23 GMT"/>
							<outline text="docs: config.rssDocs," created="Wed, 03 Jun 2026 21:05:27 GMT"/>
							<outline text="maxFeedItems: config.rssMaxFeedItems," created="Wed, 03 Jun 2026 21:05:38 GMT"/>
							<outline text="flRssCloudEnabled: config.rssCloudPort," created="Wed, 03 Jun 2026 21:05:53 GMT"/>
							<outline text="rssCloudDomain: config.rssCloudDomain," created="Wed, 03 Jun 2026 21:06:09 GMT"/>
							<outline text="rssCloudPort: config.rssCloudPort," created="Wed, 03 Jun 2026 21:06:21 GMT"/>
							<outline text="rssCloudPath: config.rssCloudPath," created="Wed, 03 Jun 2026 22:03:29 GMT"/>
							<outline text="rssCloudRegisterProcedure: config.rssCloudRegisterProcedure," created="Wed, 03 Jun 2026 21:07:08 GMT"/>
							<outline text="rssCloudProtocol: config.rssCloudProtocol," created="Wed, 03 Jun 2026 21:07:10 GMT"/>
							<outline text="generator: myProductName + &quot; v&quot; + myVersion,"/>
							<outline text="}" created="Wed, 03 Jun 2026 21:05:04 GMT"/>
							</outline>
						<outline text="return (headElements);" created="Wed, 03 Jun 2026 21:18:17 GMT"/>
						<outline text="}" created="Wed, 03 Jun 2026 21:17:57 GMT"/>
						</outline>
					<outline text="function publishCommentsFeed (idPost, callback) { //7/8/26 by CC">
						<outline text="buildCommentsFeed (idPost, function (err, xmltext, parentItem) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;publishCommentsFeed: err.message == &quot; + err.message);"/>
								<outline text="if (callback !== undefined) {">
									<outline text="callback (err);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="const relpath = parentItem.screenname + &quot;/comments/&quot; + idPost + &quot;.xml&quot;;"/>
								<outline text="const s3path = config.rssS3Path + relpath;"/>
								<outline text="s3.newObject (s3path, xmltext, &quot;text/xml&quot;, &quot;public-read&quot;, function (err, data) {">
									<outline text="if (err) {">
										<outline text="console.log (&quot;publishCommentsFeed: config.rssS3Path == &quot; + config.rssS3Path + &quot;, err.message == &quot; + err.message);"/>
										<outline text="if (callback !== undefined) {">
											<outline text="callback (err);"/>
											<outline text="}"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="if (callback !== undefined) {">
											<outline text="callback (undefined, parentItem);"/>
											<outline text="}"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="});"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function updateReplyFeedsOnS3 (idParent, commenterScreenname) { //7/8/26 by CC">
						<outline text="Changes" isComment="true" created="Wed, 08 Jul 2026 13:37:27 GMT">
							<outline text="7/8/26; 9:37:32 AM by CC" created="Wed, 08 Jul 2026 13:37:30 GMT">
								<outline text="everything that must rebuild because a reply changed: the parent's comments feed, plus the parent author's own feeds (their user feed carries the parent item, whose count attribute changed) " created="Wed, 08 Jul 2026 13:37:32 GMT"/>
								</outline>
							</outline>
						<outline text="if (idParent !== undefined) {" created="Wed, 08 Jul 2026 13:43:28 GMT">
							<outline text="publishCommentsFeed (idParent, function (err, parentItem) {">
								<outline text="if (err) {">
									<outline text="console.log (&quot;updateReplyFeedsOnS3: err.message == &quot; + err.message);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="if (parentItem.screenname !== commenterScreenname) {">
										<outline text="getUserInfoByScreenname (parentItem.screenname, function (err, parentUserRec) {">
											<outline text="if (err) {">
												<outline text="console.log (&quot;updateReplyFeedsOnS3: err.message == &quot; + err.message);"/>
												<outline text="}"/>
												</outline>
											<outline text="else {">
												<outline text="updateFeedsOnS3 (parentUserRec, function (err) {">
													<outline text="if (err) {">
														<outline text="console.log (&quot;updateReplyFeedsOnS3: err.message == &quot; + err.message);"/>
														<outline text="}"/>
														</outline>
													<outline text="});"/>
													</outline>
												<outline text="}"/>
												</outline>
											<outline text="});"/>
											</outline>
										<outline text="}"/>
										</outline>
									<outline text="if (parentItem.inReplyToNum !== undefined) { //7/8/26 by CC">
										<outline text="publishCommentsFeed (parentItem.inReplyToNum);"/>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="}" created="Wed, 08 Jul 2026 13:43:36 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function buildFeedItems (items, flSourceAttribution=false) { //6/3/26 by DW" created="Wed, 03 Jun 2026 21:31:09 GMT">
						<outline text="Changes" isComment="true" created="Wed, 08 Jul 2026 13:53:57 GMT">
							<outline text="7/8/26; 9:54:00 AM by DW" created="Wed, 08 Jul 2026 13:54:00 GMT">
								<outline text="New optional param, flSourceAttribution -- if true, each item carries the RSS core &lt;source&gt; element: the author's feedUrl and display name (screenname when their feed title is empty). For feeds that mix authors " created="Wed, 08 Jul 2026 13:54:04 GMT"/>
								</outline>
							</outline>
						<outline text="var feedItems = new Array ();"/>
						<outline text="items.forEach (function (theItem) {">
							<outline text="var feedItem = {">
								<outline text="text: theItem.description,"/>
								<outline text="when: theItem.pubDate,"/>
								<outline text="title: theItem.title,"/>
								<outline text="link: theItem.link,"/>
								<outline text="guid: {flPermalink: true, value: theItem.guid},"/>
								<outline text="markdowntext: theItem.markdowntext,"/>
								<outline text="account: { //6/26/26 by DW" created="Fri, 26 Jun 2026 21:50:22 GMT">
									<outline text="service: config.myDomain," created="Tue, 21 Mar 2023 13:38:12 GMT"/>
									<outline text="name: theItem.screenname" created="Tue, 21 Mar 2023 13:38:17 GMT"/>
									<outline text="}" created="Fri, 26 Jun 2026 21:50:28 GMT"/>
									</outline>
								<outline text="};"/>
								</outline>
							<outline text="if (theItem.enclosureUrl !== undefined) {">
								<outline text="feedItem.enclosure = {">
									<outline text="url: theItem.enclosureUrl,"/>
									<outline text="type: theItem.enclosureType,"/>
									<outline text="length: theItem.enclosureLength"/>
									<outline text="};"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="if (theItem.inReplyToUrl !== undefined) { //5/15/26 by DW" created="Fri, 15 May 2026 22:09:15 GMT">
								<outline text="feedItem.inReplyTo = {" created="Fri, 15 May 2026 22:09:28 GMT">
									<outline text="flPermalink: true, " created="Fri, 15 May 2026 22:07:24 GMT"/>
									<outline text="value: theItem.inReplyToUrl" created="Fri, 15 May 2026 22:07:28 GMT"/>
									<outline text="};" created="Fri, 15 May 2026 22:10:07 GMT"/>
									</outline>
								<outline text="}" created="Fri, 15 May 2026 22:09:27 GMT"/>
								</outline>
							<outline text="if (theItem.ctReplies &gt; 0) { //7/8/26 by CC">
								<outline text="feedItem.comments = {">
									<outline text="count: theItem.ctReplies,"/>
									<outline text="feedUrl: getCommentsFeedUrl (theItem.screenname, theItem.id)"/>
									<outline text="};"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="if (flSourceAttribution) { //7/8/26 by CC">
								<outline text="feedItem.source = {">
									<outline text="url: theItem.feedUrl,"/>
									<outline text="title: theItem.author"/>
									<outline text="};"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="feedItems.push (feedItem);"/>
							<outline text="});"/>
							</outline>
						<outline text="return (feedItems);" created="Wed, 03 Jun 2026 21:33:30 GMT"/>
						<outline text="}" created="Wed, 03 Jun 2026 21:31:18 GMT"/>
						</outline>
					<outline text="function buildFeedForUser (userRec, callback) {">
						<outline text="Changes" isComment="true" created="Wed, 03 Jun 2026 21:08:58 GMT">
							<outline text="6/3/26; 5:09:28 PM by DW" created="Wed, 03 Jun 2026 21:09:27 GMT">
								<outline text="Flattened rssHeadElements in config. If we leave it as a structure, then a config.json file has to change all the values to change on. " created="Wed, 03 Jun 2026 21:09:28 GMT"/>
								</outline>
							</outline>
						<outline text="const headElements = getDefaultHeadElements ();" created="Wed, 03 Jun 2026 21:04:57 GMT"/>
						<outline text="headElements.title = userRec.screenname + &quot; on rss.network&quot;;"/>
