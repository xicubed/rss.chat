									</outline>
								<outline text="theNames.forEach (function (screenname) {">
									<outline text="theOutline.opml.body.subs.push ({">
										<outline text="type: &quot;rss&quot;,"/>
										<outline text="text: screenname,"/>
										<outline text="xmlUrl: getFeedUrl (screenname)"/>
										<outline text="});"/>
										</outline>
									<outline text="});"/>
									</outline>
								<outline text="const opmltext = opml.stringify (theOutline);"/>
								<outline text="callback (undefined, opmltext);"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
