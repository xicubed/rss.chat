					<outline text="function buildCommentsFeed (idPost, callback) { //7/8/26 by CC">
						<outline text="Changes" isComment="true" created="Sun, 12 Jul 2026 15:36:03 GMT">
							<outline text="7/12/26 by CC">
								<outline text="Guard against a deleted parent. getItemAndReplies filters deleted posts, so when the parent of surviving replies has been deleted, parentItem comes back undefined and the build crashed on parentItem.title. Now it answers: &quot;Can't build the comments feed for post N because the post has been deleted.&quot; Live trigger: reply to a post, the author deletes the post, the reply gets edited."/>
								</outline>
							</outline>
						<outline text="getItemAndReplies (undefined, idPost, function (err, items) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (items.length == 0) {">
									<outline text="const message = &quot;Can't build the comments feed for post &quot; + idPost + &quot; because there is no post with that id.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="var parentItem, replies = new Array ();"/>
									<outline text="items.forEach (function (item) {">
										<outline text="if (item.id == idPost) {">
											<outline text="parentItem = item;"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="replies.push (item);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text=""/>
									<outline text="if (parentItem === undefined) { //7/12/26 by CC">
										<outline text="const message = &quot;Can't build the comments feed for post &quot; + idPost + &quot; because the post has been deleted.&quot;;"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="const headElements = getDefaultHeadElements ();"/>
										<outline text="var parentName = &quot;post &quot; + idPost;"/>
										<outline text="if (parentItem.title !== undefined) {">
											<outline text="parentName = &quot;\&quot;&quot; + parentItem.title + &quot;\&quot;&quot;;"/>
											<outline text="}"/>
											</outline>
										<outline text="headElements.title = &quot;Comments on &quot; + parentName;"/>
										<outline text="headElements.link = parentItem.guid;"/>
										<outline text="headElements.description = &quot;Replies to &quot; + parentName + &quot; by &quot; + parentItem.screenname + &quot; on &quot; + config.myDomain;"/>
										<outline text="headElements.urlSelf = getCommentsFeedUrl (parentItem.screenname, idPost);"/>
										<outline text=""/>
										<outline text="const feedItems = buildFeedItems (replies, true); //7/8/26 by DW -- include &lt;source&gt; attributions"/>
										<outline text="const xmltext = rss.buildRssFeed (headElements, feedItems);"/>
										<outline text="callback (undefined, xmltext, parentItem);"/>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function buildCommentsFeed (idPost, callback) { //7/8/26 by CC" isComment="true">
						<outline text="Changes" isComment="true" created="Wed, 08 Jul 2026 13:24:02 GMT">
							<outline text="7/8/26; 9:24:05 AM by DW" created="Wed, 08 Jul 2026 13:24:04 GMT">
								<outline text="Started." created="Wed, 08 Jul 2026 13:24:05 GMT"/>
								</outline>
							</outline>
						<outline text="getItemAndReplies (undefined, idPost, function (err, items) {">
							<outline text="if (err) {">
								<outline text="callback (err);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="if (items.length == 0) {">
									<outline text="const message = &quot;Can't build the comments feed for post &quot; + idPost + &quot; because there is no post with that id.&quot;;"/>
									<outline text="callback ({message});"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="var parentItem, replies = new Array ();"/>
									<outline text="items.forEach (function (item) {">
										<outline text="if (item.id == idPost) {">
											<outline text="parentItem = item;"/>
											<outline text="}"/>
											</outline>
										<outline text="else {">
											<outline text="replies.push (item);"/>
											<outline text="}"/>
											</outline>
										<outline text="});"/>
										</outline>
									<outline text=""/>
									<outline text="const headElements = getDefaultHeadElements ();"/>
									<outline text="var parentName = &quot;post &quot; + idPost;"/>
									<outline text="if (parentItem.title !== undefined) {">
										<outline text="parentName = &quot;\&quot;&quot; + parentItem.title + &quot;\&quot;&quot;;"/>
										<outline text="}"/>
										</outline>
									<outline text="headElements.title = &quot;Comments on &quot; + parentName;"/>
									<outline text="headElements.link = parentItem.guid;"/>
									<outline text="headElements.description = &quot;Replies to &quot; + parentName + &quot; by &quot; + parentItem.screenname + &quot; on &quot; + config.myDomain;"/>
									<outline text="headElements.urlSelf = getCommentsFeedUrl (parentItem.screenname, idPost);"/>
									<outline text=""/>
									<outline text="const feedItems = buildFeedItems (replies, true); //7/8/26 by DW -- include &lt;source&gt; attributions"/>
									<outline text="const xmltext = rss.buildRssFeed (headElements, feedItems);"/>
									<outline text="callback (undefined, xmltext, parentItem);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function buildFeedForEveryone (feedUrl, callback) { //6/3/26 by DW">
						<outline text="console.log (&quot;buildFeedForEveryone&quot;);" isComment="true" created="Wed, 24 Jun 2026 19:30:41 GMT"/>
