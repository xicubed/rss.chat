			<outline text="rssnetwork.js">
				<outline text="var myVersion = &quot;0.5.25&quot;, myProductName = &quot;rss.network&quot;;"/>
				<outline text=""/>
				<outline text="const daveappserver = require (&quot;daveappserver&quot;);"/>
				<outline text="const rss = require (&quot;daverss&quot;);"/>
				<outline text="const s3 = require (&quot;daves3&quot;);"/>
				<outline text="const utils = require (&quot;daveutils&quot;);"/>
				<outline text="const opml = require (&quot;opml&quot;);" created="Sat, 20 Feb 2021 22:03:12 GMT"/>
				<outline text="const fs = require (&quot;fs&quot;);"/>
				<outline text="const path = require (&quot;path&quot;);"/>
				<outline text="const request = require (&quot;request&quot;);     "/>
				<outline text="const davesql = require (&quot;davesql&quot;); "/>
				<outline text="const turndown = require (&quot;turndown&quot;); //5/3/26 by DW"/>
				<outline text="const autolinker = require (&quot;autolinker&quot;); //7/13/26 by CC"/>
				<outline text=""/>
