							<outline text="else {">
								<outline text="const feedItems = buildFeedItems (items, true); //7/8/26 by DW -- add source elements to indicate who the author is" created="Wed, 03 Jun 2026 21:34:29 GMT"/>
								<outline text="const xmltext = rss.buildRssFeed (headElements, feedItems);"/>
								<outline text="if (callback !== undefined) {" created="Wed, 24 Jun 2026 19:25:13 GMT">
									<outline text="callback (undefined, xmltext);"/>
