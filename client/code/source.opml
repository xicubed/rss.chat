				<outline text="//themes -- 5/1/26 by DW" created="Fri, 01 May 2026 14:47:50 GMT">
					<outline text="function updateTheme (themeName, callback) {" created="Fri, 01 May 2026 14:47:55 GMT">
						<outline text="Changes" isComment="true" created="Sat, 30 May 2026 14:34:47 GMT">
							<outline text="7/7/26; 11:19:02 AM by DW" created="Tue, 07 Jul 2026 15:19:02 GMT">
								<outline text="Added a cache confuser." created="Tue, 07 Jul 2026 15:19:03 GMT"/>
								</outline>
							<outline text="5/30/26; 10:34:51 AM by DW" created="Sat, 30 May 2026 14:34:50 GMT">
								<outline text="new callback param. we load the current theme's css and js files from s3." created="Sat, 30 May 2026 14:34:52 GMT"/>
								</outline>
							</outline>
						<outline text="const cacheConfuser = &quot;?x=&quot; + new Date ().getTime (), whenstart = new Date ();" created="Tue, 07 Jul 2026 15:26:24 GMT"/>
						<outline text="if (themeName === undefined) {" created="Fri, 01 May 2026 21:25:41 GMT">
							<outline text="themeName = appPrefs.currentThemeName;" created="Fri, 01 May 2026 21:26:41 GMT"/>
							<outline text="}" created="Fri, 01 May 2026 21:26:29 GMT"/>
							</outline>
						<outline text="console.log (&quot;switchTheme: themeName == &quot; + themeName);" created="Fri, 01 May 2026 14:48:26 GMT"/>
						<outline text="const baseUrl = appConsts.urlThemes + themeName + &quot;/&quot;;" created="Sat, 30 May 2026 14:06:02 GMT"/>
						<outline text="" created="Sat, 30 May 2026 14:01:19 GMT"/>
						<outline text="function installJavaScriptCode (theCode) {">
							<outline text="$(&quot;#scriptTheme&quot;).remove ();"/>
							<outline text="const scriptTheme = document.createElement (&quot;script&quot;);"/>
							<outline text="scriptTheme.id = &quot;scriptTheme&quot;;"/>
							<outline text="scriptTheme.textContent = theCode;"/>
							<outline text="document.head.appendChild (scriptTheme);"/>
							<outline text="}"/>
							</outline>
						<outline text="function installCssStyles (theStyles) {">
							<outline text="$(&quot;#styleTheme&quot;).remove ();"/>
							<outline text="const styleTheme = document.createElement (&quot;style&quot;);"/>
							<outline text="styleTheme.id = &quot;styleTheme&quot;;"/>
							<outline text="styleTheme.textContent = theStyles;"/>
							<outline text="document.head.appendChild (styleTheme);"/>
							<outline text="}"/>
							</outline>
						<outline text="" created="Sat, 30 May 2026 14:09:44 GMT"/>
						<outline text="const urlStyles = baseUrl + &quot;theme.css&quot; + cacheConfuser;" created="Sat, 30 May 2026 14:06:32 GMT"/>
						<outline text="httpRequest (urlStyles, undefined, undefined, function (err, cssText) {">
							<outline text="if (err) {">
								<outline text="console.log (&quot;updateTheme: urlStyles == &quot; + urlStyles + &quot;, err.message == &quot; + err.message);"/>
								<outline text="const message = &quot;Can't boot up, because we failed to load theme styles from the server.&quot;;" created="Sat, 30 May 2026 14:35:49 GMT"/>
								<outline text="callback ({message});"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="const urlCode = baseUrl + &quot;theme.js&quot; + cacheConfuser;" created="Sat, 30 May 2026 14:06:32 GMT"/>
								<outline text="httpRequest (urlCode, undefined, undefined, function (err, jsText) {">
									<outline text="if (err) {">
										<outline text="console.log (&quot;updateTheme: urlCode == &quot; + urlCode + &quot;, err.message == &quot; + err.message);"/>
										<outline text="const message = &quot;Can't boot up, because we failed to load theme code from the server.&quot;;" created="Sat, 30 May 2026 14:35:49 GMT"/>
										<outline text="callback ({message});"/>
										<outline text="}"/>
										</outline>
									<outline text="else {">
										<outline text="installJavaScriptCode (jsText)" created="Fri, 01 May 2026 21:03:42 GMT"/>
										<outline text="installCssStyles (cssText);" created="Fri, 01 May 2026 21:04:11 GMT"/>
										<outline text="console.log (&quot;updateTheme: &quot; + secondsSince (whenstart) + &quot; secs.&quot;);"/>
										<outline text="callback (undefined);" created="Sat, 30 May 2026 14:18:43 GMT"/>
										<outline text="}"/>
										</outline>
									<outline text="});"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text="" isComment="true" created="Sat, 30 May 2026 14:01:20 GMT"/>
						<outline text="const theTheme = themes [themeName];" isComment="true" created="Fri, 01 May 2026 21:00:28 GMT"/>
						<outline text="installJavaScriptCode (theTheme.code)" isComment="true" created="Fri, 01 May 2026 21:03:42 GMT"/>
						<outline text="installCssStyles (theTheme.styles);" isComment="true" created="Fri, 01 May 2026 21:04:11 GMT"/>
						<outline text="}" created="Fri, 01 May 2026 14:48:33 GMT"/>
						</outline>
