									<outline text="&lt;/div&gt;"/>
									</outline>
								<outline text="&lt;/div&gt;"/>
								</outline>
							<outline text="&lt;/div&gt;" created="Thu, 28 Mar 2013 21:39:17 GMT" pgfnum="21616"/>
							</outline>
						<outline text="&lt;div class=&quot;divChatContainer&quot;&gt;" created="Wed, 29 Apr 2026 15:16:41 GMT">
							<outline text="&lt;/div&gt;" created="Wed, 29 Apr 2026 15:16:54 GMT"/>
							</outline>
						<outline text="&lt;script&gt;">
							<outline text="$(document).ready (function () {">
								<outline text="startup ();" created="Wed, 30 Oct 2013 15:20:06 GMT" pgfnum="30656"/>
								<outline text="});"/>
								</outline>
							<outline text="&lt;/script&gt;"/>
							</outline>
						<outline text="&lt;/body&gt;"/>
						</outline>
					<outline text="&lt;/html&gt;"/>
					</outline>
				</outline>
			<outline text="old stuff" isComment="true" created="Fri, 10 Jul 2026 14:06:03 GMT">
				<outline text="chat.css" isComment="true">
					<outline text="@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;display=swap');"/>
					<outline text=""/>
					<outline text=":root {">
						<outline text="--bg:        #e5ddd5;"/>
						<outline text="--header-bg: #075e54;"/>
						<outline text="--mine-bg:   #dcf8c6;"/>
						<outline text="--theirs-bg: #ffffff;"/>
						<outline text="--input-bg:  #f0f0f0;"/>
						<outline text="--send-bg:   #075e54;"/>
						<outline text="--text:      #111;"/>
						<outline text="--subtext:   #667781;"/>
						<outline text="--sender:    #1a9c7b;"/>
						<outline text="--tick:      #53bdeb;"/>
						<outline text="--radius:    18px;"/>
						<outline text="--shadow:    0 1px 2px rgba(0,0,0,.13);"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divChat {">
						<outline text="width: 375px;"/>
						<outline text="height: 700px;"/>
						<outline text="background: var(--bg);"/>
						<outline text="border-radius: 36px;"/>
						<outline text="overflow: hidden;"/>
						<outline text="box-shadow: 0 24px 80px rgba(0,0,0,.4), inset 0 0 0 1px rgba(255,255,255,.15);"/>
						<outline text="display: flex;"/>
						<outline text="flex-direction: column;"/>
						<outline text="margin: 40px auto 0 auto;"/>
						<outline text="font-family: 'Inter', -apple-system, sans-serif;"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divHeader {">
						<outline text="background: var(--header-bg);"/>
						<outline text="padding: 10px 12px;"/>
						<outline text="display: flex;"/>
						<outline text="align-items: center;"/>
						<outline text="gap: 10px;"/>
						<outline text="flex-shrink: 0;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBackArrow {">
						<outline text="color: white;"/>
						<outline text="font-size: 20px;"/>
						<outline text="cursor: pointer;"/>
						<outline text="padding-right: 2px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divAvatar {">
						<outline text="width: 38px;"/>
						<outline text="height: 38px;"/>
						<outline text="border-radius: 50%;"/>
						<outline text="background: #128c7e;"/>
						<outline text="color: white;"/>
						<outline text="font-size: 18px;"/>
						<outline text="font-weight: 600;"/>
						<outline text="display: flex;"/>
						<outline text="align-items: center;"/>
						<outline text="justify-content: center;"/>
						<outline text="flex-shrink: 0;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divHeaderInfo {">
						<outline text="flex: 1;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divHeaderName {">
						<outline text="color: white;"/>
						<outline text="font-size: 15px;"/>
						<outline text="font-weight: 600;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divHeaderStatus {">
						<outline text="color: rgba(255,255,255,.7);"/>
						<outline text="font-size: 12px;"/>
						<outline text="margin-top: 1px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divHeaderIcons {">
						<outline text="display: flex;"/>
						<outline text="gap: 16px;"/>
						<outline text="color: white;"/>
						<outline text="font-size: 18px;"/>
						<outline text="cursor: pointer;"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divMessageContainer {">
						<outline text="flex: 1;"/>
						<outline text="overflow-y: auto;"/>
						<outline text="padding: 10px 8px;"/>
						<outline text="display: flex;"/>
						<outline text="flex-direction: column;"/>
						<outline text="gap: 2px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divMessageContainer::-webkit-scrollbar { width: 4px; }"/>
					<outline text=".divMessageContainer::-webkit-scrollbar-thumb { background: rgba(0,0,0,.2); border-radius: 2px; }"/>
					<outline text=""/>
					<outline text=".divDateDivider {">
						<outline text="text-align: center;"/>
						<outline text="margin: 8px 0;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divDateDivider span {">
						<outline text="background: rgba(255,255,255,.75);"/>
						<outline text="color: var(--subtext);"/>
						<outline text="font-size: 11.5px;"/>
						<outline text="padding: 3px 10px;"/>
						<outline text="border-radius: 8px;"/>
						<outline text="box-shadow: var(--shadow);"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divThread {">
						<outline text="display: flex;"/>
						<outline text="flex-direction: column;"/>
						<outline text="width: 100%;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divThread + .divThread.mine   { margin-top: 1px; }"/>
					<outline text=".divThread + .divThread.theirs { margin-top: 1px; }"/>
					<outline text=".divThread.tail + .divThread   { margin-top: 4px; }"/>
					<outline text=""/>
					<outline text=".divReplies {">
						<outline text="display: flex;"/>
						<outline text="flex-direction: column;"/>
						<outline text="gap: 2px;"/>
						<outline text="padding-left: 24px;"/>
						<outline text="margin-top: 2px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divReplies:empty {">
						<outline text="display: none;"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divBubble {">
						<outline text="max-width: 75%;"/>
						<outline text="padding: 6px 10px 4px 10px;"/>
						<outline text="border-radius: var(--radius);"/>
						<outline text="box-shadow: var(--shadow);"/>
						<outline text="position: relative;"/>
						<outline text="word-break: break-word;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBubble.mine {">
						<outline text="background: var(--mine-bg);"/>
						<outline text="align-self: flex-end;"/>
						<outline text="border-bottom-right-radius: 4px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBubble.theirs {">
						<outline text="background: var(--theirs-bg);"/>
						<outline text="align-self: flex-start;"/>
						<outline text="border-bottom-left-radius: 4px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBubble.noTail { border-radius: var(--radius); }"/>
					<outline text=""/>
					<outline text=".divSenderName {">
						<outline text="color: var(--sender);"/>
						<outline text="font-size: 12px;"/>
						<outline text="font-weight: 600;"/>
						<outline text="margin-bottom: 2px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBubbleText {">
						<outline text="color: var(--text);"/>
						<outline text="font-size: 14px;"/>
						<outline text="line-height: 1.4;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divBubbleMeta {">
						<outline text="display: flex;"/>
						<outline text="justify-content: flex-end;"/>
						<outline text="align-items: center;"/>
						<outline text="gap: 3px;"/>
						<outline text="margin-top: 2px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divTimestamp {">
						<outline text="color: var(--subtext);"/>
						<outline text="font-size: 11px;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divTicks {">
						<outline text="color: var(--tick);"/>
						<outline text="font-size: 13px;"/>
						<outline text="line-height: 1;"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".divInputBar {">
						<outline text="background: var(--input-bg);"/>
						<outline text="padding: 8px 10px;"/>
						<outline text="display: flex;"/>
						<outline text="align-items: center;"/>
						<outline text="gap: 8px;"/>
						<outline text="flex-shrink: 0;"/>
						<outline text="}"/>
						</outline>
					<outline text=".divEmojiButton {">
						<outline text="font-size: 22px;"/>
						<outline text="cursor: pointer;"/>
						<outline text="flex-shrink: 0;"/>
						<outline text="}"/>
						</outline>
					<outline text=".editorInput {">
						<outline text="flex: 1;"/>
						<outline text="border: none;"/>
						<outline text="border-radius: 22px;"/>
						<outline text="padding: 9px 14px;"/>
						<outline text="font-size: 14.5px;"/>
						<outline text="font-family: inherit;"/>
						<outline text="background: white;"/>
						<outline text="outline: none;"/>
						<outline text="color: var(--text);"/>
						<outline text="box-shadow: var(--shadow);"/>
						<outline text="}"/>
						</outline>
					<outline text=".editorInput:disabled {">
						<outline text="background: #e0e0e0;"/>
						<outline text="color: #999;"/>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text=".sendButton {">
						<outline text="width: 42px;"/>
						<outline text="height: 42px;"/>
						<outline text="border-radius: 50%;"/>
						<outline text="background: var(--send-bg);"/>
						<outline text="border: none;"/>
						<outline text="color: white;"/>
						<outline text="font-size: 18px;"/>
						<outline text="cursor: pointer;"/>
						<outline text="display: flex;"/>
						<outline text="align-items: center;"/>
						<outline text="justify-content: center;"/>
						<outline text="flex-shrink: 0;"/>
						<outline text="transition: background .15s;"/>
						<outline text="}"/>
						</outline>
					<outline text=".sendButton:hover { background: #128c7e; }"/>
					</outline>
				<outline text="chat.js" isComment="true">
					<outline text="function chatUserInterface (userOptions) { //4/29/26 by Claude + DW">
						<outline text="console.log (&quot;chatUserInterface&quot;);"/>
						<outline text=""/>
						<outline text="var options = {">
							<outline text="whereToAppend: undefined, //i want the designer to tell us where it goes -- 4/29/26 by DW"/>
							<outline text="micIcon: &quot;&amp;#x1F3A4;&quot;, //microphone"/>
							<outline text="sendIcon: &quot;&amp;#x27A4;&quot;, //rightward arrow"/>
							<outline text="placeholderSignedIn: &quot;Message&quot;,"/>
							<outline text="placeholderSignedOut: &quot;Sign in to post&quot;,"/>
							<outline text="ctRecentItems: 100,"/>
							<outline text="};"/>
							</outline>
						<outline text="mergeOptions (userOptions, options);"/>
						<outline text=""/>
						<outline text="const divChat = $(&quot;&lt;div class=\&quot;divChat\&quot;&gt;&lt;/div&gt;&quot;);"/>
						<outline text=""/>
						<outline text="var getEditorText, clearEditor, setEditorEnabled; //assigned by getTextEditor"/>
						<outline text="var onEditorSubmit, onEditorInput; //callbacks assigned by chat constructor"/>
						<outline text=""/>
						<outline text="const sendButton = $(&quot;&lt;button class=\&quot;sendButton\&quot;&gt;&quot; + options.micIcon + &quot;&lt;/button&gt;&quot;);"/>
						<outline text="const divMessageContainer = $(&quot;&lt;div class=\&quot;divMessageContainer\&quot;&gt;&lt;/div&gt;&quot;);"/>
						<outline text=""/>
						<outline text="const itemsById = {}; //look up parent bubble when an item with inReplyTo arrives"/>
						<outline text=""/>
						<outline text="var theLastFeedUrl = undefined;"/>
						<outline text="var theLastDateString = undefined;"/>
						<outline text=""/>
						<outline text="function getTimeString (theDate) {">
							<outline text="return (theDate.toLocaleTimeString ([], {hour: &quot;2-digit&quot;, minute: &quot;2-digit&quot;}));"/>
							<outline text="}"/>
							</outline>
						<outline text="function getDateLabel (theDate) {">
							<outline text="const now = new Date ();"/>
							<outline text="const today = new Date (now.getFullYear (), now.getMonth (), now.getDate ());"/>
							<outline text="const dateOnly = new Date (theDate.getFullYear (), theDate.getMonth (), theDate.getDate ());"/>
							<outline text="const diffDays = (today - dateOnly) / 86400000;"/>
							<outline text="if (diffDays &lt; 1) {">
								<outline text="return (&quot;Today&quot;);"/>
								<outline text="}"/>
								</outline>
							<outline text="if (diffDays &lt; 2) {">
								<outline text="return (&quot;Yesterday&quot;);"/>
								<outline text="}"/>
								</outline>
							<outline text="return (theDate.toLocaleDateString ([], {month: &quot;long&quot;, day: &quot;numeric&quot;, year: &quot;numeric&quot;}));"/>
							<outline text="}"/>
							</outline>
						<outline text=""/>
						<outline text="function addItemToTimeline (item, flScroll) { //adds item to display">
							<outline text="const theDate = new Date (item.pubDate);"/>
							<outline text="const flMine = globals.myRssNetwork.userIsSignedIn () &amp;&amp; (item.feedUrl === globals.myRssNetwork.getFeedUrl ());"/>
							<outline text="const dateString = theDate.toDateString ();"/>
							<outline text=""/>
							<outline text="function getDateDivider () {">
								<outline text="const divDateDivider = $(&quot;&lt;div class=\&quot;divDateDivider\&quot;&gt;&lt;/div&gt;&quot;);"/>
								<outline text="const spanLabel = $(&quot;&lt;span&gt;&lt;/span&gt;&quot;).text (getDateLabel (theDate));"/>
								<outline text="divDateDivider.append (spanLabel);"/>
								<outline text="return (divDateDivider);"/>
								<outline text="}"/>
								</outline>
							<outline text="function getSenderName () {">
								<outline text="const divSenderName = $(&quot;&lt;div class=\&quot;divSenderName\&quot;&gt;&lt;/div&gt;&quot;).text (item.author);"/>
								<outline text="return (divSenderName);"/>
								<outline text="}"/>
								</outline>
							<outline text="function getBubbleText () {">
								<outline text="const divBubbleText = $(&quot;&lt;div class=\&quot;divBubbleText\&quot;&gt;&lt;/div&gt;&quot;).text (item.description);"/>
								<outline text="return (divBubbleText);"/>
								<outline text="}"/>
								</outline>
							<outline text="function getBubbleMeta () {">
								<outline text="const divBubbleMeta = $(&quot;&lt;div class=\&quot;divBubbleMeta\&quot;&gt;&lt;/div&gt;&quot;);"/>
								<outline text="const spanTimestamp = $(&quot;&lt;span class=\&quot;divTimestamp\&quot;&gt;&quot; + getTimeString (theDate) + &quot;&lt;/span&gt;&quot;);"/>
								<outline text="divBubbleMeta.append (spanTimestamp);"/>
								<outline text="if (flMine) {">
									<outline text="const spanTicks = $(&quot;&lt;span class=\&quot;divTicks\&quot;&gt;&amp;#x2713;&amp;#x2713;&lt;/span&gt;&quot;); //double checkmark"/>
									<outline text="divBubbleMeta.append (spanTicks);"/>
									<outline text="}"/>
									</outline>
								<outline text="return (divBubbleMeta);"/>
								<outline text="}"/>
								</outline>
							<outline text="function getBubble (flTail) {">
								<outline text="const sideClass = flMine ? &quot;mine&quot; : &quot;theirs&quot;;"/>
								<outline text="const tailClass = flTail ? &quot;tail&quot; : &quot;noTail&quot;;"/>
								<outline text="const divBubble = $(&quot;&lt;div class=\&quot;divBubble &quot; + sideClass + &quot; &quot; + tailClass + &quot;\&quot;&gt;&lt;/div&gt;&quot;);"/>
								<outline text="if (!flMine &amp;&amp; flTail) {">
									<outline text="divBubble.append (getSenderName ());"/>
									<outline text="}"/>
									</outline>
								<outline text="divBubble.append (getBubbleText ());"/>
								<outline text="divBubble.append (getBubbleMeta ());"/>
								<outline text="return (divBubble);"/>
								<outline text="}"/>
								</outline>
							<outline text=""/>
							<outline text="const parentEntry = (item.inReplyTo === undefined) ? undefined : itemsById [item.inReplyTo];"/>
							<outline text="var divParent, flTail;"/>
							<outline text="if (parentEntry === undefined) { //top-level item -- date divider, tail by feedUrl change, attach to message container">
								<outline text="if (dateString !== theLastDateString) {">
									<outline text="divMessageContainer.append (getDateDivider ());"/>
									<outline text="theLastDateString = dateString;"/>
									<outline text="theLastFeedUrl = undefined;"/>
									<outline text="}"/>
									</outline>
								<outline text="flTail = (item.feedUrl !== theLastFeedUrl);"/>
								<outline text="theLastFeedUrl = item.feedUrl;"/>
								<outline text="divParent = divMessageContainer;"/>
								<outline text="}"/>
								</outline>
							<outline text="else { //reply -- always show sender, attach inside parent's divReplies">
								<outline text="flTail = true;"/>
								<outline text="divParent = parentEntry.divReplies;"/>
								<outline text="}"/>
								</outline>
							<outline text="const divBubble = getBubble (flTail);"/>
							<outline text="const divReplies = $(&quot;&lt;div class=\&quot;divReplies\&quot;&gt;&lt;/div&gt;&quot;);"/>
							<outline text="divBubble.append (divReplies);"/>
							<outline text="divParent.append (divBubble);"/>
							<outline text="itemsById [item.id] = {divBubble, divReplies};"/>
							<outline text=""/>
							<outline text="if (flScroll) {">
								<outline text="divMessageContainer.scrollTop (divMessageContainer [0].scrollHeight);"/>
								<outline text="}"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text=""/>
						<outline text="function sendMessage () {">
							<outline text="console.log (&quot;sendMessage&quot;);"/>
							<outline text="const text = getEditorText ();"/>
							<outline text="if (text.length === 0) {">
								<outline text="return;"/>
								<outline text="}"/>
								</outline>
							<outline text="if (!globals.myRssNetwork.userIsSignedIn ()) {">
								<outline text="return;"/>
								<outline text="}"/>
								</outline>
							<outline text="const item = {">
								<outline text="feedUrl: globals.myRssNetwork.getFeedUrl (),"/>
								<outline text="author: globals.myRssNetwork.getScreenname (),"/>
								<outline text="description: text,"/>
								<outline text="pubDate: new Date ().toISOString ()"/>
								<outline text="};"/>
								</outline>
							<outline text="if (appConsts.flPostItemsLocally) { //4/24/26 by DW">
								<outline text="addItemToTimeline (item, true);"/>
								<outline text="}"/>
								</outline>
							<outline text="clearEditor ();"/>
							<outline text="sendButton.html (options.micIcon);"/>
							<outline text="const postRec = {">
								<outline text="description: text"/>
								<outline text="};"/>
								</outline>
							<outline text="globals.myRssNetwork.newPost (postRec, function (err, data) {">
								<outline text="if (err) {">
									<outline text="console.log (&quot;sendItem: err.message == &quot; + err.message);"/>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text=""/>
						<outline text="function refresh () {">
							<outline text="setEditorEnabled (globals.myRssNetwork.userIsSignedIn ());"/>
							<outline text="}"/>
							</outline>
						<outline text="function loadRecentItems () { //4/29/26 by DW">
							<outline text="globals.myRssNetwork.getRecentItems (options.ctRecentItems, function (err, theItems) {">
								<outline text="if (err) {">
									<outline text="console.log (&quot;loadRecentItems: err.message == &quot; + err.message);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="theItems.reverse (); //display oldest first, newest at bottom"/>
									<outline text="theItems.forEach (function (item) {">
										<outline text="addItemToTimeline (item, false);"/>
										<outline text="});"/>
										</outline>
									<outline text="divMessageContainer.scrollTop (divMessageContainer [0].scrollHeight);"/>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text=""/>
						<outline text="function getHeader () {">
							<outline text="const divHeader = $(&quot;&lt;div class=\&quot;divHeader\&quot;&gt;&lt;/div&gt;&quot;);"/>
							<outline text="const divBackArrow = $(&quot;&lt;div class=\&quot;divBackArrow\&quot;&gt;&amp;#x2190;&lt;/div&gt;&quot;); //leftwards arrow"/>
							<outline text="const divAvatar = $(&quot;&lt;div class=\&quot;divAvatar\&quot;&gt;r&lt;/div&gt;&quot;);"/>
							<outline text="const divHeaderInfo = $(&quot;&lt;div class=\&quot;divHeaderInfo\&quot;&gt;&lt;/div&gt;&quot;);"/>
							<outline text="const divHeaderName = $(&quot;&lt;div class=\&quot;divHeaderName\&quot;&gt;rss.network&lt;/div&gt;&quot;);"/>
							<outline text="const divHeaderStatus = $(&quot;&lt;div class=\&quot;divHeaderStatus\&quot;&gt;online&lt;/div&gt;&quot;);"/>
							<outline text="divHeaderInfo.append (divHeaderName);"/>
							<outline text="divHeaderInfo.append (divHeaderStatus);"/>
							<outline text="const divHeaderIcons = $(&quot;&lt;div class=\&quot;divHeaderIcons\&quot;&gt;&lt;span title=\&quot;More\&quot;&gt;&amp;#x22EE;&lt;/span&gt;&lt;/div&gt;&quot;); //vertical ellipsis"/>
							<outline text="divHeader.append (divBackArrow);"/>
							<outline text="divHeader.append (divAvatar);"/>
							<outline text="divHeader.append (divHeaderInfo);"/>
							<outline text="divHeader.append (divHeaderIcons);"/>
							<outline text="return (divHeader);"/>
							<outline text="}"/>
							</outline>
						<outline text="function getTextEditor () {">
							<outline text="const divTextEditor = $(&quot;&lt;div class=\&quot;divTextEditor\&quot;&gt;&lt;/div&gt;&quot;);"/>
							<outline text="const editorInput = $(&quot;&lt;input type=\&quot;text\&quot; class=\&quot;editorInput\&quot; /&gt;&quot;);"/>
							<outline text="divTextEditor.append (editorInput);"/>
							<outline text=""/>
							<outline text="editorInput.on (&quot;input&quot;, function () {">
								<outline text="if (onEditorInput !== undefined) {">
									<outline text="onEditorInput ();"/>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text="editorInput.on (&quot;keydown&quot;, function (event) {">
								<outline text="if (event.key === &quot;Enter&quot;) {">
									<outline text="if (onEditorSubmit !== undefined) {">
										<outline text="onEditorSubmit ();"/>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="});"/>
								</outline>
							<outline text=""/>
							<outline text="getEditorText = function () {">
								<outline text="return (editorInput.val ().trim ());"/>
								<outline text="};"/>
								</outline>
							<outline text="clearEditor = function () {">
								<outline text="editorInput.val (&quot;&quot;);"/>
								<outline text="};"/>
								</outline>
							<outline text="setEditorEnabled = function (flBool) {">
								<outline text="if (flBool) {">
									<outline text="editorInput.prop (&quot;disabled&quot;, false);"/>
									<outline text="editorInput.attr (&quot;placeholder&quot;, options.placeholderSignedIn);"/>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="editorInput.prop (&quot;disabled&quot;, true);"/>
									<outline text="editorInput.attr (&quot;placeholder&quot;, options.placeholderSignedOut);"/>
									<outline text="}"/>
									</outline>
								<outline text="};"/>
								</outline>
							<outline text=""/>
							<outline text="return (divTextEditor);"/>
							<outline text="}"/>
							</outline>
						<outline text="function getInputBar () {">
							<outline text="const divInputBar = $(&quot;&lt;div class=\&quot;divInputBar\&quot;&gt;&lt;/div&gt;&quot;);"/>
							<outline text="const divEmojiButton = $(&quot;&lt;div class=\&quot;divEmojiButton\&quot;&gt;&amp;#x1F642;&lt;/div&gt;&quot;); //slightly smiling face"/>
							<outline text="divInputBar.append (divEmojiButton);"/>
							<outline text="divInputBar.append (getTextEditor ());"/>
							<outline text="divInputBar.append (sendButton);"/>
							<outline text="return (divInputBar);"/>
							<outline text="}"/>
							</outline>
						<outline text=""/>
						<outline text="divChat.append (getHeader ());"/>
						<outline text="divChat.append (divMessageContainer);"/>
						<outline text="divChat.append (getInputBar ());"/>
						<outline text="options.whereToAppend.append (divChat);"/>
						<outline text=""/>
						<outline text="onEditorInput = function () {">
							<outline text="sendButton.html (getEditorText () ? options.sendIcon : options.micIcon);"/>
							<outline text="};"/>
							</outline>
						<outline text="onEditorSubmit = sendMessage;"/>
						<outline text="sendButton.on (&quot;click&quot;, function () {">
							<outline text="if (getEditorText ()) {">
								<outline text="sendMessage ();"/>
								<outline text="}"/>
								</outline>
							<outline text="});"/>
							</outline>
						<outline text=""/>
						<outline text="refresh ();"/>
						<outline text="loadRecentItems (); //4/29/26 by DW"/>
						<outline text=""/>
						<outline text="this.newItem = function (item) {">
							<outline text="console.log (&quot;chatUserInterface.newItem&quot;);"/>
							<outline text="addItemToTimeline (item, true);"/>
							<outline text="};"/>
							</outline>
						<outline text="this.refresh = refresh;"/>
						<outline text="}"/>
						</outline>
					</outline>
				<outline text="signupdialog.css" isComment="true" created="Fri, 06 Jan 2023 21:24:59 GMT">
					<outline text=".divSignupDialog {" created="Wed, 03 Jan 2024 14:40:42 GMT">
						<outline text="left: 50%;" created="Wed, 03 Jan 2024 14:40:58 GMT"/>
						<outline text="width: 570px;" created="Wed, 03 Jan 2024 14:41:04 GMT"/>
						<outline text="}" created="Wed, 03 Jan 2024 14:40:50 GMT"/>
						</outline>
					<outline text=".divSignupDialog .inputForName {" created="Fri, 06 Jan 2023 14:40:16 GMT">
						<outline text="font-size: 17px;" created="Fri, 06 Jan 2023 14:40:35 GMT"/>
						<outline text="padding: 3px;" created="Fri, 06 Jan 2023 14:40:39 GMT"/>
						<outline text="width: 10em;" created="Fri, 06 Jan 2023 14:40:45 GMT"/>
						<outline text="height: auto;" created="Fri, 06 Jan 2023 14:56:24 GMT"/>
						<outline text="border: 1px solid green;" isComment="true" created="Fri, 06 Jan 2023 15:09:17 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 14:40:48 GMT"/>
						</outline>
					<outline text=".divSignupDialog .xlarge {" created="Fri, 06 Jan 2023 15:25:07 GMT">
						<outline text="font-size: 16px;" created="Fri, 06 Jan 2023 14:40:35 GMT"/>
						<outline text="height: auto;" created="Fri, 06 Jan 2023 14:56:24 GMT"/>
						<outline text="margin-bottom: 0;" created="Fri, 06 Jan 2023 17:33:08 GMT"/>
						<outline text="width: 150px;" isComment="true" created="Fri, 06 Jan 2023 15:30:23 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 15:25:24 GMT"/>
						</outline>
					<outline text=".divSignupDialog .divPreamble {" created="Fri, 06 Jan 2023 16:18:15 GMT">
						<outline text="font-size: 15px;" created="Fri, 06 Jan 2023 16:18:27 GMT"/>
						<outline text="margin-bottom: 20px;" created="Fri, 06 Jan 2023 16:18:32 GMT"/>
						<outline text="text-align: center;" created="Fri, 06 Jan 2023 16:20:44 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 16:18:26 GMT"/>
						</outline>
					<outline text=".divSignupDialog .modal-footer {" created="Fri, 06 Jan 2023 16:18:15 GMT">
						<outline text="margin-top: 10px;" created="Fri, 06 Jan 2023 16:18:32 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 16:18:26 GMT"/>
						</outline>
					<outline text=".divSignupDialog .spComment {">
						<outline text="font-size: 13px;" created="Fri, 06 Jan 2023 16:18:27 GMT"/>
						<outline text="margin-left: 3px;" created="Fri, 06 Jan 2023 17:35:23 GMT"/>
						<outline text="opacity: .5;" created="Fri, 06 Jan 2023 17:35:30 GMT"/>
						<outline text="color: green;" isComment="true" created="Thu, 12 Jan 2023 17:33:29 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 17:17:58 GMT"/>
						</outline>
					<outline text=".divSignupDialog .commentIsError {" created="Thu, 12 Jan 2023 17:33:21 GMT">
						<outline text="color: red;" isComment="true" created="Thu, 12 Jan 2023 17:33:29 GMT"/>
						<outline text="}" created="Thu, 12 Jan 2023 17:33:24 GMT"/>
						</outline>
					<outline text=".divSignupDialog h3 {" created="Fri, 06 Jan 2023 15:25:07 GMT">
						<outline text="font-size: 18px;" created="Fri, 06 Jan 2023 14:40:35 GMT"/>
						<outline text="}" created="Fri, 06 Jan 2023 15:25:24 GMT"/>
						</outline>
					</outline>
				<outline text="signupdialog.js" isComment="true" created="Mon, 06 Jun 2022 15:20:22 GMT">
					<outline text="function signupDialog (userOptions) {" created="Mon, 04 Apr 2022 14:42:43 GMT">
						<outline text="Changes" isComment="true" created="Mon, 04 Apr 2022 14:48:27 GMT">
							<outline text="6/17/26; 3:26:52 PM by DW" created="Wed, 17 Jun 2026 19:26:51 GMT">
								<outline text="Modified so it can be called from rssNetwork app. " created="Wed, 17 Jun 2026 19:26:52 GMT">
									<outline text="options.canCreateAccountCallback is new -- it's there for the whitelist code" created="Wed, 17 Jun 2026 19:41:24 GMT">
										<outline text="returns an error if you can't create it. " created="Thu, 18 Jun 2026 14:35:20 GMT"/>
										</outline>
									<outline text="options.extraLegalChars is an array, if one of those chars comes in, we accept it" created="Thu, 18 Jun 2026 14:47:09 GMT"/>
									</outline>
								</outline>
							<outline text="4/4/22; 10:55:51 AM by DW" created="Mon, 04 Apr 2022 14:55:50 GMT">
								<outline text="The ask dialog as a closure. Here's the HTML we construct (at start)." created="Mon, 04 Apr 2022 14:55:52 GMT">
									<outline text="&lt;div class=&quot;divAskDialog&quot; style=&quot;left: 50%; width: 570px;&quot;&gt;" isComment="true">
										<outline text="&lt;div id=&quot;idAskDialog&quot; class=&quot;modal hide fade&quot; tabindex=&quot;-1&quot; role=&quot;dialog&quot; aria-labelledby=&quot;windowTitleLabel&quot; aria-hidden=&quot;true&quot;&gt;">
											<outline text="&lt;div class=&quot;modal-header&quot;&gt;">
												<outline text="&lt;a href=&quot;#&quot; class=&quot;close&quot; data-dismiss=&quot;modal&quot;&gt;&amp;times;&lt;/a&gt;"/>
												<outline text="&lt;h3 id=&quot;idAskDialogPrompt&quot; style=&quot;font-size: 18px;&quot;&gt;&lt;/h3&gt;"/>
												<outline text="&lt;/div&gt;"/>
												</outline>
											<outline text="&lt;div class=&quot;modal-body&quot;&gt;">
												<outline text="&lt;input class=&quot;xlarge&quot; id=&quot;idAskDialogInput&quot; name=&quot;xlInput&quot; type=&quot;text&quot; style=&quot;font-size: 17px; padding: 3px; height: auto; width: 515px;&quot; /&gt;"/>
												<outline text="&lt;/div&gt;"/>
												</outline>
											<outline text="&lt;div class=&quot;modal-footer&quot;&gt;">
												<outline text="&lt;a href=&quot;#&quot; class=&quot;btn&quot; onclick=&quot;cancelAskDialog ();&quot; style=&quot;width: 80px; margin-left: 5px;&quot;&gt;Cancel&lt;/a&gt;"/>
												<outline text="&lt;a href=&quot;#&quot; class=&quot;btn btn-primary&quot; onclick=&quot;okAskDialog ();&quot; style=&quot;width: 80px; margin-left: 5px;&quot;&gt;OK&lt;/a&gt;"/>
												<outline text="&lt;/div&gt;"/>
												</outline>
											<outline text="&lt;/div&gt;"/>
											</outline>
										<outline text="&lt;/div&gt;"/>
										</outline>
									</outline>
								</outline>
							</outline>
						<outline text="function getSavedValue (theValue) {" created="Thu, 12 Jan 2023 16:39:49 GMT">
							<outline text="const val = (theValue === undefined) ? &quot;&quot; : theValue;" created="Thu, 12 Jan 2023 16:40:03 GMT"/>
							<outline text="return (val);" created="Thu, 12 Jan 2023 16:40:27 GMT"/>
							<outline text="}" created="Thu, 12 Jan 2023 16:39:59 GMT"/>
							</outline>
						<outline text="" created="Wed, 17 Jun 2026 20:20:28 GMT"/>
						<outline text="var options = {" created="Thu, 05 Jan 2023 22:31:33 GMT">
							<outline text="prompt: &quot;Choose a name and enter your email address.&quot;," created="Thu, 05 Jan 2023 22:31:43 GMT"/>
							<outline text="preamble: &quot;When you're ready, click the Send button to get a confirming email.&quot;," created="Fri, 06 Jan 2023 16:17:13 GMT"/>
							<outline text="preamble: &quot;We'll explain something interesting that helps people get the idea.&quot;," isComment="true" created="Fri, 06 Jan 2023 16:17:13 GMT"/>
							<outline text="" created="Fri, 06 Jan 2023 16:17:14 GMT"/>
							<outline text="defaultNameValue: getSavedValue (localStorage.signupName)," created="Thu, 05 Jan 2023 22:33:11 GMT"/>
							<outline text="placeholderForName: &quot;1. Choose a name&quot;," created="Thu, 05 Jan 2023 22:34:08 GMT"/>
							<outline text="minNameLength: 4," created="Fri, 06 Jan 2023 17:41:28 GMT"/>
							<outline text="" created="Fri, 06 Jan 2023 15:42:54 GMT"/>
							<outline text="defaultEmailValue: getSavedValue (localStorage.signupEmail)," created="Thu, 05 Jan 2023 22:33:11 GMT"/>
							<outline text="placeholderForEmail: &quot;2. Enter your email address&quot;," created="Thu, 05 Jan 2023 22:34:08 GMT"/>
