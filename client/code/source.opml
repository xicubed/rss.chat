					<outline text="function myAboutDialog () { //6/28/26 by DW" created="Mon, 06 Nov 2023 13:54:45 GMT">
						<outline text="console.log (&quot;myAboutDialog&quot;);" created="Mon, 06 Nov 2023 13:55:15 GMT"/>
