				<outline text="//handling socket items -- 4/23/26 by DW" created="Thu, 23 Apr 2026 12:14:52 GMT">
					<outline text="var idsSeen = new Array ();" created="Fri, 24 Apr 2026 14:51:44 GMT"/>
					<outline text="" created="Fri, 24 Apr 2026 14:51:44 GMT"/>
					<outline text="function ageoutIdsSeen () { //age out items in idsSeen array" created="Fri, 24 Apr 2026 15:45:18 GMT">
						<outline text="var newArray = new Array ();" created="Fri, 24 Apr 2026 15:25:09 GMT"/>
						<outline text="idsSeen.forEach (function (item) {" created="Fri, 24 Apr 2026 15:25:09 GMT">
							<outline text="if (secondsSince (item.when) &lt; appConsts.maxSecsForIds) {" created="Fri, 24 Apr 2026 15:25:29 GMT">
								<outline text="newArray.push (item);" created="Fri, 24 Apr 2026 15:26:38 GMT"/>
								<outline text="}" created="Fri, 24 Apr 2026 15:25:54 GMT"/>
								</outline>
							<outline text="else {" created="Fri, 24 Apr 2026 15:42:46 GMT">
								<outline text="console.log (&quot;ageoutIdsSeen: ageing out == &quot; + jsonStringify (item));" isComment="true" created="Fri, 24 Apr 2026 15:42:50 GMT"/>
								<outline text="}" created="Fri, 24 Apr 2026 15:43:05 GMT"/>
								</outline>
							<outline text="});" created="Fri, 24 Apr 2026 15:25:20 GMT"/>
							</outline>
						<outline text="idsSeen = newArray;"/>
						<outline text="}" created="Fri, 24 Apr 2026 15:45:28 GMT"/>
						</outline>
					<outline text="" created="Mon, 18 May 2026 13:15:00 GMT"/>
					<outline text="function isFeedInExtras (feedUrl) { //5/18/26 by DW" created="Mon, 18 May 2026 13:15:02 GMT">
						<outline text="" created="Mon, 18 May 2026 14:16:38 GMT"/>
						<outline text="return (false); //feature disabled -- 5/18/26 by DW" created="Mon, 18 May 2026 14:16:38 GMT"/>
						<outline text="" created="Mon, 18 May 2026 14:16:38 GMT"/>
						<outline text="var flFound = false;" created="Sun, 17 May 2026 20:52:28 GMT"/>
						<outline text="globals.userData.extrasList.forEach (function (xmlUrl) {" created="Sun, 17 May 2026 20:47:59 GMT">
							<outline text="if (xmlUrl === feedUrl) {" created="Sun, 17 May 2026 20:51:31 GMT">
								<outline text="flFound = true;" created="Sun, 17 May 2026 20:52:22 GMT"/>
								<outline text="}" created="Sun, 17 May 2026 20:51:38 GMT"/>
								</outline>
							<outline text="});" created="Sun, 17 May 2026 20:51:06 GMT"/>
							</outline>
						<outline text="return (flFound);" created="Mon, 18 May 2026 13:16:16 GMT"/>
						<outline text="}" created="Mon, 18 May 2026 13:15:52 GMT"/>
						</outline>
					<outline text="function includeSocketItem (theItem) { " created="Thu, 23 Apr 2026 12:25:10 GMT">
						<outline text="Changes" isComment="true" created="Fri, 24 Apr 2026 14:56:09 GMT">
							<outline text="6/8/26; 10:08:20 AM by DW" created="Mon, 08 Jun 2026 14:08:20 GMT">
								<outline text="Don't include globals.userData.feedUrlEveryone." created="Mon, 08 Jun 2026 14:08:21 GMT"/>
								</outline>
							<outline text="5/17/26; 4:53:25 PM by DW" created="Sun, 17 May 2026 20:53:18 GMT">
								<outline text="Added support for extras list. " created="Sun, 17 May 2026 20:53:26 GMT"/>
								</outline>
							<outline text="4/24/26; 10:56:12 AM by DW" created="Fri, 24 Apr 2026 14:56:11 GMT">
								<outline text="Only inclide an item from the socket if it's one of ours and we haven't seen it before. " created="Fri, 24 Apr 2026 14:56:12 GMT"/>
								</outline>
							</outline>
						<outline text="//exclude items we've already seen" created="Fri, 24 Apr 2026 15:35:40 GMT">
							<outline text="var flInclude = true; " created="Fri, 24 Apr 2026 14:52:18 GMT"/>
							<outline text="idsSeen.forEach (function (item) {" created="Fri, 24 Apr 2026 14:52:18 GMT">
								<outline text="if (item.id === theItem.id) {" created="Fri, 24 Apr 2026 14:52:38 GMT">
									<outline text="flInclude = false;" created="Fri, 24 Apr 2026 14:52:52 GMT"/>
									<outline text="}" created="Fri, 24 Apr 2026 14:52:45 GMT"/>
									</outline>
								<outline text="});" created="Fri, 24 Apr 2026 14:52:33 GMT"/>
								</outline>
							<outline text="if (flInclude) {" created="Fri, 24 Apr 2026 14:54:54 GMT">
								<outline text="idsSeen.push ({" created="Fri, 24 Apr 2026 14:55:28 GMT">
									<outline text="id: theItem.id," created="Fri, 24 Apr 2026 14:55:37 GMT"/>
									<outline text="when: new Date ()" created="Fri, 24 Apr 2026 14:55:44 GMT"/>
									<outline text="})" created="Fri, 24 Apr 2026 14:55:50 GMT"/>
									</outline>
								<outline text="}" created="Fri, 24 Apr 2026 14:55:02 GMT"/>
								</outline>
							<outline text="else {" created="Fri, 24 Apr 2026 15:19:38 GMT">
								<outline text="return (false); //don't include, already seen" created="Fri, 24 Apr 2026 15:19:52 GMT"/>
								<outline text="}" created="Fri, 24 Apr 2026 15:19:40 GMT"/>
								</outline>
							</outline>
						<outline text="//include items from our feeds" created="Fri, 24 Apr 2026 15:18:55 GMT">
							<outline text="const baseFeedUrl = globals.myRssNetwork.getBaseFeedUrl ();" isComment="true" created="Wed, 22 Apr 2026 17:06:59 GMT"/>
							<outline text="if (beginsWith (theItem.feedUrl, globals.userData.baseFeedUrl)) {" created="Thu, 23 Apr 2026 12:22:35 GMT">
								<outline text="if (theItem.feedUrl == globals.userData.feedUrlEveryone) { //6/8/26 by DW" created="Mon, 08 Jun 2026 14:06:17 GMT">
									<outline text="return (false);" created="Thu, 23 Apr 2026 12:23:35 GMT"/>
									<outline text="}" created="Mon, 08 Jun 2026 14:06:25 GMT"/>
									</outline>
								<outline text="else {" created="Mon, 08 Jun 2026 14:06:26 GMT">
									<outline text="return (true);" created="Thu, 23 Apr 2026 12:23:35 GMT"/>
									<outline text="}" created="Mon, 08 Jun 2026 14:06:28 GMT"/>
									</outline>
								<outline text="}" created="Thu, 23 Apr 2026 12:23:11 GMT"/>
								</outline>
							<outline text="else {" created="Thu, 23 Apr 2026 12:23:45 GMT">
								<outline text="if (isFeedInExtras (theItem.feedUrl)) {" created="Mon, 18 May 2026 13:16:37 GMT">
									<outline text="return (true);" created="Sun, 17 May 2026 20:52:59 GMT"/>
									<outline text="}" created="Mon, 18 May 2026 13:16:46 GMT"/>
									</outline>
								<outline text="else {" created="Mon, 18 May 2026 13:18:11 GMT">
									<outline text="return (appConsts.flIncludeAllSocketItems);" created="Thu, 23 Apr 2026 12:24:07 GMT"/>
									<outline text="}" created="Mon, 18 May 2026 13:18:13 GMT"/>
									</outline>
								<outline text="}" created="Thu, 23 Apr 2026 12:23:47 GMT"/>
								</outline>
							</outline>
						<outline text="}" created="Thu, 23 Apr 2026 12:25:19 GMT"/>
						</outline>
					<outline text="" created="Sun, 21 Jun 2026 14:06:45 GMT"/>
					<outline text="function socketItemHandler (flNew, theFeed, theItem) { //6/21/26 by CC">
						<outline text="Changes" isComment="true" created="Sun, 21 Jun 2026 14:06:00 GMT">
							<outline text="6/21/26 by CC" created="Sun, 21 Jun 2026 14:06:03 GMT">
								<outline text="socket delivers a render-ready item now; no refetch, no theFeed merge" created="Sun, 21 Jun 2026 14:06:04 GMT"/>
								</outline>
							</outline>
						<outline text="if (includeSocketItem (theItem)) {">
							<outline text="console.log (&quot;socketItemHandler: flNew == &quot; + flNew + &quot;, feedUrl == &quot; + theItem.feedUrl);"/>
							<outline text="if (flNew) {">
								<outline text="globals.myChatUserInterface.newItem (theItem);"/>
								<outline text="}"/>
								</outline>
							<outline text="else {">
								<outline text="globals.myChatUserInterface.updateItem (theItem);"/>
								<outline text="}"/>
