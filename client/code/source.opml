						<outline text="add (&quot;&lt;li&gt;MySQL version: v&quot; + globals.userData.mySqlVersion + &quot;&lt;/li&gt;&quot;);" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
						<outline text=""/>
