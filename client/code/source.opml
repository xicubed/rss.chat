					<outline text="cursor: pointer;" created="Tue, 07 Jul 2026 15:34:30 GMT"/>
					<outline text="}" created="Sat, 15 Mar 2025 01:36:58 GMT"/>
					</outline>
				<outline text=".divTabsFromOutline { /* 5/27/26 by DW -- used in settings dialog */">
					<outline text="font-size: 16px;" created="Wed, 27 May 2026 15:35:13 GMT"/>
					<outline text="}" created="Wed, 27 May 2026 15:35:21 GMT"/>
					</outline>
				<outline text="" created="Sun, 28 Jun 2026 13:53:11 GMT"/>
				<outline text=".divAboutDialogText ul { /* 6/28/26 by DW */" created="Mon, 06 Nov 2023 14:12:27 GMT">
					<outline text="list-style-type: none;" created="Mon, 06 Nov 2023 14:12:38 GMT"/>
					<outline text="margin: 0;" created="Mon, 06 Nov 2023 14:16:07 GMT"/>
					<outline text="padding-top: 10px;" created="Mon, 06 Nov 2023 14:17:06 GMT"/>
					<outline text="}" created="Mon, 06 Nov 2023 14:12:33 GMT"/>
					</outline>
				<outline text=".divAboutDialogText li {">
					<outline text="margin-top: 5px;"/>
					<outline text="line-height: 140%;" created="Mon, 06 Nov 2023 14:18:13 GMT"/>
