					<outline text="for (var i = 0; i &lt; theList.length; i++) {">
						<outline text="var lt = theList [i];"/>
						<outline text="if ((lt.length &gt; 0) &amp;&amp; (lt != &quot;&lt;p&gt;&quot;) &amp;&amp; (lt != &quot;&lt;/p&gt;&quot;)) {">
							<outline text="markdowntext += &quot;&lt;p&gt;&quot; + md.makeHtml (lt) + &quot;&lt;/p&gt;&quot;;"/>
							<outline text="}"/>
