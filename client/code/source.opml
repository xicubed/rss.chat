				<outline text="function applyUserCss (theCss) { //5/28/26 by DW">
					<outline text="const idStyle = &quot;idUserCss&quot;;"/>
					<outline text="$(&quot;#&quot; + idStyle).remove (); //clear any style we added on a previous call"/>
					<outline text="var theStyle = $(&quot;&lt;style&gt;&lt;/style&gt;&quot;);"/>
					<outline text="theStyle.attr (&quot;id&quot;, idStyle);"/>
					<outline text="theStyle.text (theCss);"/>
					<outline text="theStyle.appendTo (&quot;head&quot;);"/>
