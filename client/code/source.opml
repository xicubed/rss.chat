						<outline text="add (&quot;&lt;li&gt;Server address: &quot; + linkToServer + &quot;&lt;/li&gt;&quot;);" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
						<outline text="add (&quot;&lt;li&gt;Server version: v&quot; + globals.userData.serverVersion + &quot;.&lt;/li&gt;&quot;); //7/1/26 by DW" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
						<outline text="add (&quot;&lt;li&gt;Client version: v&quot; + appConsts.version + &quot;.&lt;/li&gt;&quot;); //7/2/26 by DW" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
						<outline text="add (&quot;&lt;li&gt;Server version: v&quot; + settingsFromServer.appServerVersion + &quot;.&lt;/li&gt;&quot;); //commented -- this is the version for daveAppServer" isComment="true" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
						<outline text="add (&quot;&lt;li&gt;Current theme: &quot; + appPrefs.currentThemeName + &quot;&lt;/li&gt;&quot;);" created="Mon, 06 Nov 2023 14:00:03 GMT"/>
