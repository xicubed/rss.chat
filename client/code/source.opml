			<outline text="settings.opml">
				<outline text="Feed" created="Wed, 27 May 2026 15:22:19 GMT">
					<outline text="&lt;p&gt;You can set the title, link and description for the feed that we maintain for you.&lt;/p&gt;"/>
					<outline text="&lt;%prefs.stringPref (&quot;TItle&quot;, &quot;myFeedTitle&quot;, &quot;Your feed's title.&quot;)%&gt;"/>
					<outline text="&lt;%prefs.stringPref (&quot;Link&quot;, &quot;myFeedLink&quot;, &quot;Link to your home page or profile site.&quot;)%&gt;"/>
					<outline text="&lt;%prefs.textAreaPref (&quot;Description&quot;, &quot;myFeedDescription&quot;, &quot;A short description of your feed.&quot;, rows:3)%&gt;"/>
					<outline text="&lt;%prefs.stringPref (&quot;Avatar URL&quot;, &quot;myAvatarImageUrl&quot;, &quot;A square image that represents you on the net.&quot;)%&gt;"/>
					</outline>
				<outline text="Prompts" created="Sun, 24 May 2026 14:23:09 GMT">
					<outline text="&lt;%prefs.stringPref (&quot;New post&quot;, &quot;placeholderSignedIn&quot;, &quot;What's happening?&quot;)%&gt;"/>
					<outline text="&lt;%prefs.stringPref (&quot;Reply&quot;, &quot;placeholderReply&quot;, &quot;Post your reply&quot;)%&gt;"/>
					</outline>
				<outline text="CSS" created="Sat, 06 Dec 2025 15:52:15 GMT">
					<outline text="&lt;%prefs.checkboxPref (&quot;Apply this CSS code at startup.&quot;, &quot;flApplyUserCss&quot;)%&gt;"/>
					<outline text="&lt;%prefs.textAreaPref (&quot;CSS&quot;, &quot;userCss&quot;, &quot;These styles will be inserted when the app starts up, if the checkbox above is checked. If you want to start over, delete all the text and save.&quot;, 70, 10)%&gt;"/>
					</outline>
				</outline>
			<outline text="api.js" created="Sun, 19 Apr 2026 15:57:44 GMT">
				<outline text="function rssNetworkServer (userOptions) {">
					<outline text="var rssNetworkMemory = { //saved in localStorage">
						<outline text="email: undefined,"/>
						<outline text="code: undefined,"/>
						<outline text="screenname: undefined"/>
						<outline text="};"/>
						</outline>
					<outline text="var options = {">
						<outline text="serverAddress: undefined"/>
						<outline text="};"/>
						</outline>
					<outline text="mergeOptions (userOptions, options);"/>
					<outline text="" created="Wed, 22 Apr 2026 17:51:48 GMT"/>
					<outline text="var myFeedUrl = undefined, baseFeedUrl = undefined;" created="Wed, 22 Apr 2026 17:51:48 GMT"/>
					<outline text="var flWillRedirect = false; //5/17/26 by DW -- will be true if we're redirecting when things settle down" created="Sun, 17 May 2026 16:06:29 GMT"/>
					<outline text=""/>
					<outline text="function saveMemory () {">
						<outline text="localStorage.rssNetworkMemory = JSON.stringify (rssNetworkMemory);"/>
						<outline text="}"/>
						</outline>
					<outline text="function loadMemory () {">
						<outline text="if (localStorage.rssNetworkMemory !== undefined) {">
							<outline text="var jstruct = JSON.parse (localStorage.rssNetworkMemory);"/>
							<outline text="for (var x in jstruct) {">
								<outline text="rssNetworkMemory [x] = jstruct [x];"/>
								<outline text="}"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getLinkToAppPage () {">
						<outline text="return (stringNthField (stringNthField (window.location.href, &quot;?&quot;, 1), &quot;#&quot;, 1));"/>
						<outline text="}"/>
						</outline>
					<outline text="function handleEmailConfirm () {">
						<outline text="var params = new URLSearchParams (location.search);"/>
						<outline text="if (params.get (&quot;emailconfirmed&quot;) === &quot;true&quot;) {">
							<outline text="rssNetworkMemory.email = params.get (&quot;email&quot;);"/>
							<outline text="rssNetworkMemory.code = params.get (&quot;code&quot;);"/>
							<outline text="rssNetworkMemory.screenname = params.get (&quot;screenname&quot;);"/>
							<outline text="saveMemory ();"/>
							<outline text="flWillRedirect = true; //5/17/26 by DW" created="Sun, 17 May 2026 16:07:33 GMT"/>
							<outline text="location.href = getLinkToAppPage ();"/>
							<outline text="" isComment="true" created="Sun, 10 May 2026 16:20:01 GMT"/>
							<outline text="localStorage.debugParams = location.search; //5/10/26 by DW" isComment="true" created="Sun, 10 May 2026 16:20:01 GMT"/>
							<outline text="}"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function buildQueryString (params) {">
						<outline text="var result = &quot;&quot;;"/>
						<outline text="if (params !== undefined) {">
							<outline text="for (var x in params) {">
								<outline text="if (params [x] !== undefined) {">
									<outline text="if (result.length &gt; 0) {">
										<outline text="result += &quot;&amp;&quot;;"/>
										<outline text="}"/>
										</outline>
									<outline text="result += encodeURIComponent (x) + &quot;=&quot; + encodeURIComponent (params [x]);"/>
									<outline text="}"/>
									</outline>
								<outline text="}"/>
								</outline>
							<outline text="}"/>
							</outline>
						<outline text="return (result);"/>
						<outline text="}"/>
						</outline>
					<outline text="function servercall (path, params, flAuthenticated, method, callback) {">
						<outline text="Changes" isComment="true" created="Fri, 12 Jun 2026 16:12:06 GMT">
							<outline text="6/12/26; 12:12:09 PM by DW" created="Fri, 12 Jun 2026 16:12:08 GMT">
								<outline text="Added flAuthenticated param. If true we add the params for authentication, rather than having to replicate the code in every call." created="Fri, 12 Jun 2026 16:12:09 GMT"/>
								<outline text="If this had been cc'd from FeedLand we would have gotten the params right the first time. " created="Fri, 12 Jun 2026 16:16:30 GMT"/>
								</outline>
							</outline>
						<outline text="method = (method === undefined) ? &quot;GET&quot; : method;"/>
						<outline text="var url = options.serverAddress + path;"/>
						<outline text="" created="Fri, 12 Jun 2026 16:12:53 GMT"/>
						<outline text="if (params === undefined) { //6/12/26 by DW">
							<outline text="params = new Object ();"/>
							<outline text="}"/>
							</outline>
						<outline text="if (getBoolean (flAuthenticated)) {" created="Fri, 12 Jun 2026 16:12:53 GMT">
							<outline text="params.emailaddress = rssNetworkMemory.email;" created="Fri, 12 Jun 2026 16:15:31 GMT"/>
							<outline text="params.emailcode = rssNetworkMemory.code;" created="Fri, 12 Jun 2026 16:15:56 GMT"/>
							<outline text="}" created="Fri, 12 Jun 2026 16:13:15 GMT"/>
							</outline>
						<outline text="" created="Fri, 12 Jun 2026 16:12:54 GMT"/>
						<outline text="var qs = buildQueryString (params);"/>
						<outline text="if (qs.length &gt; 0) {">
							<outline text="url += &quot;?&quot; + qs;"/>
							<outline text="}"/>
							</outline>
						<outline text="fetch (url, {method}) .then (function (response) {">
							<outline text="return (response.text () .then (function (responseText) {">
								<outline text="if (response.ok) {">
									<outline text="try {" created="Sat, 16 May 2026 21:57:18 GMT">
										<outline text="const jstruct = JSON.parse (responseText);" created="Sat, 16 May 2026 21:57:34 GMT"/>
										<outline text="callback (undefined, jstruct);" created="Sat, 16 May 2026 21:57:42 GMT"/>
										<outline text="}" created="Sat, 16 May 2026 21:57:22 GMT"/>
										</outline>
									<outline text="catch (err) {" created="Sat, 16 May 2026 21:57:23 GMT">
										<outline text="callback (err);" created="Sat, 16 May 2026 21:57:28 GMT"/>
										<outline text="}" created="Sat, 16 May 2026 21:57:26 GMT"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="else {">
									<outline text="try {">
										<outline text="const jstruct = JSON.parse (responseText);"/>
										<outline text="callback (jstruct);"/>
										<outline text="}"/>
										</outline>
									<outline text="catch (err) {">
										<outline text="callback ({message: responseText});"/>
										<outline text="}"/>
										</outline>
									<outline text="}"/>
									</outline>
								<outline text="else {" isComment="true">
									<outline text="callback ({message: responseText});"/>
									<outline text="}"/>
									</outline>
								<outline text="}));"/>
								</outline>
							<outline text="})"/>
							</outline>
						<outline text=".catch (function (err) {">
							<outline text="callback (err);"/>
							<outline text="});"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text=""/>
					<outline text="function createAccount (email, name=undefined, callback) {">
						<outline text="Changes" isComment="true" created="Mon, 15 Jun 2026 17:13:23 GMT">
							<outline text="6/15/26; 1:13:28 PM by DW" created="Mon, 15 Jun 2026 17:13:26 GMT">
								<outline text="Added new optional param, name, defaults to everything to the left of @ in email address." created="Mon, 15 Jun 2026 17:13:29 GMT"/>
								</outline>
							</outline>
						<outline text="var params = {">
							<outline text="email,"/>
							<outline text="name: (name == undefined) ? trimWhitespace (stringNthField (email, &quot;@&quot;, 1)) : name,"/>
							<outline text="urlredirect: getLinkToAppPage ()"/>
							<outline text="};"/>
							</outline>
						<outline text="servercall (&quot;createnewuser&quot;, params, false, &quot;GET&quot;, callback); //this is in daveappserver -- 6/5/26 by DW"/>
						<outline text="}"/>
						</outline>
					<outline text="function signIn (email, callback) {">
						<outline text="var params = {">
							<outline text="email,"/>
							<outline text="name: trimWhitespace (stringNthField (email, &quot;@&quot;, 1))," isComment="true"/>
							<outline text="urlredirect: getLinkToAppPage ()"/>
							<outline text="};"/>
							</outline>
						<outline text="servercall (&quot;sendconfirmingemail&quot;, params, false, &quot;GET&quot;, callback);"/>
						<outline text="}"/>
						</outline>
					<outline text="function getFeedUrl () {">
						<outline text="return (myFeedUrl);" created="Wed, 22 Apr 2026 17:56:17 GMT"/>
						<outline text="}"/>
						</outline>
					<outline text="function getBaseFeedUrl () {">
						<outline text="return (baseFeedUrl);" created="Wed, 22 Apr 2026 17:56:17 GMT"/>
						<outline text="}"/>
						</outline>
					<outline text="function getFeed (screenname, callback) {">
						<outline text="servercall (&quot;feed&quot;, {screenname}, false, &quot;GET&quot;, callback);"/>
						<outline text="}"/>
						</outline>
					<outline text="function getUserData (screenname, callback) {" created="Wed, 22 Apr 2026 22:41:38 GMT">
						<outline text="servercall (&quot;getuserdata&quot;, {screenname}, true, &quot;GET&quot;, callback);"/>
						<outline text="}" created="Wed, 22 Apr 2026 22:41:57 GMT"/>
						</outline>
					<outline text="function getSubscriptionList (callback) {" created="Thu, 23 Apr 2026 14:16:50 GMT">
						<outline text="servercall (&quot;getsubscriptionlist&quot;, undefined, false, &quot;GET&quot;, callback);"/>
						<outline text="}" created="Thu, 23 Apr 2026 14:17:07 GMT"/>
						</outline>
					<outline text="function newPost (postRec, callback) {">
						<outline text="Changes" isComment="true" created="Thu, 30 Apr 2026 15:27:18 GMT">
							<outline text="4/30/26; 11:27:20 AM by DW" created="Thu, 30 Apr 2026 15:27:19 GMT">
								<outline text="first param changed to postRec." created="Thu, 30 Apr 2026 15:27:21 GMT"/>
								</outline>
							</outline>
						<outline text="if (userIsSignedIn ()) {" created="Mon, 20 Apr 2026 14:38:09 GMT">
							<outline text="const params = {">
								<outline text="emailaddress: rssNetworkMemory.email," isComment="true"/>
								<outline text="emailcode: rssNetworkMemory.code," isComment="true"/>
								<outline text="jsontext: jsonStringify (postRec)," created="Thu, 30 Apr 2026 15:35:31 GMT"/>
								<outline text="};"/>
								</outline>
							<outline text="servercall (&quot;newpost&quot;, params, true, &quot;POST&quot;, callback);"/>
							<outline text="console.log (nowstring () + &quot; rssNetworkServer.newPost: postRec == &quot; + jsonStringify (postRec)); //5/14/26 by DW" created="Thu, 14 May 2026 14:39:56 GMT"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:15 GMT"/>
							</outline>
						<outline text="else {" created="Mon, 20 Apr 2026 14:38:16 GMT">
							<outline text="const message = &quot;Can't send a new post because you are not signed in.&quot;;" created="Mon, 20 Apr 2026 14:38:35 GMT"/>
							<outline text="callback ({message});" created="Mon, 20 Apr 2026 14:38:25 GMT"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:18 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function updatePost (postRec, callback) { //5/21/26 by DW">
						<outline text="if (userIsSignedIn ()) {" created="Mon, 20 Apr 2026 14:38:09 GMT">
							<outline text="const params = {">
								<outline text="emailaddress: rssNetworkMemory.email," isComment="true"/>
								<outline text="emailcode: rssNetworkMemory.code," isComment="true"/>
								<outline text="jsontext: jsonStringify (postRec)," created="Thu, 30 Apr 2026 15:35:31 GMT"/>
								<outline text="};"/>
								</outline>
							<outline text="servercall (&quot;updatepost&quot;, params, true, &quot;POST&quot;, callback);"/>
							<outline text="console.log (nowstring () + &quot; rssNetworkServer.updatePost: postRec == &quot; + jsonStringify (postRec));" created="Thu, 14 May 2026 14:39:56 GMT"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:15 GMT"/>
							</outline>
						<outline text="else {" created="Mon, 20 Apr 2026 14:38:16 GMT">
							<outline text="const message = &quot;Can't send a new post because you are not signed in.&quot;;" created="Mon, 20 Apr 2026 14:38:35 GMT"/>
							<outline text="callback ({message});" created="Mon, 20 Apr 2026 14:38:25 GMT"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:18 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function deletePost (id, callback) { //5/21/26 by DW">
						<outline text="if (userIsSignedIn ()) {" created="Mon, 20 Apr 2026 14:38:09 GMT">
							<outline text="servercall (&quot;deletepost&quot;, {id}, true, &quot;POST&quot;, callback);"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:15 GMT"/>
							</outline>
						<outline text="else {" created="Mon, 20 Apr 2026 14:38:16 GMT">
							<outline text="const message = &quot;Can't delete the post because you are not signed in.&quot;;" created="Mon, 20 Apr 2026 14:38:35 GMT"/>
							<outline text="callback ({message});" created="Mon, 20 Apr 2026 14:38:25 GMT"/>
							<outline text="}" created="Mon, 20 Apr 2026 14:38:18 GMT"/>
							</outline>
						<outline text="}"/>
						</outline>
					<outline text="function getVersion (callback) {">
						<outline text="servercall (&quot;version&quot;, undefined, false, &quot;GET&quot;, callback);"/>
						<outline text="}"/>
						</outline>
					<outline text="function userIsSignedIn () {">
						<outline text="return ((rssNetworkMemory.email !== undefined) &amp;&amp; (rssNetworkMemory.code !== undefined));"/>
						<outline text="}"/>
						</outline>
					<outline text="function getScreenname () {">
						<outline text="return (rssNetworkMemory.screenname);"/>
						<outline text="}"/>
						</outline>
					<outline text="function getEmail () {">
						<outline text="return (rssNetworkMemory.email);"/>
						<outline text="}"/>
						</outline>
					<outline text="function signOut () {">
						<outline text="delete localStorage.rssNetworkMemory;"/>
						<outline text="location.reload ();"/>
						<outline text="}"/>
						</outline>
					<outline text="function getRecentItems (ct, callback) { //4/29/26 by DW">
						<outline text="const screenname = getScreenname (); //6/24/26 by DW" created="Wed, 24 Jun 2026 21:41:09 GMT"/>
						<outline text="servercall (&quot;getrecentitems&quot;, {screenname, ct}, false, &quot;GET&quot;, callback);"/>
						<outline text="}"/>
						</outline>
					<outline text="function savePrefs (thePrefs, callback) { //5/16/26 by DW" created="Sat, 16 May 2026 21:24:54 GMT">
						<outline text="if (userIsSignedIn ()) {" created="Mon, 20 Apr 2026 14:38:09 GMT">
							<outline text="const params = {">
								<outline text="emailaddress: rssNetworkMemory.email," isComment="true"/>
								<outline text="emailcode: rssNetworkMemory.code," isComment="true"/>
								<outline text="jsontext: jsonStringify (thePrefs)," created="Thu, 30 Apr 2026 15:35:31 GMT"/>
								<outline text="};"/>
